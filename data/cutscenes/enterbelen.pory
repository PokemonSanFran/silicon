script EnterBelen_PutMeatInOven_Dialogue
{
    lockall
    call(EnterBelen_NotReady_Dialogue)
    setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_SAVE_BEFORE_LEADER)
    msgbox(format("Hold on! I've got one brushing of Pinap glaze..."),,SPEAKER_BELEN)
    closemessage
    applymovement(LOCALID_MERMEREZA_GYM_BELEN, Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    delay(24)
    msgbox(format("Excellente, all set! Follow me to the battlefield."), MSGBOX_NPC,SPEAKER_BELEN)
    closemessage
    //applymovement(LOCALID_PLAYER,moves(walk_left * 4))
    //applymovement(LOCALID_MERMEREZA_GYM_BELEN,moves(walk_left * 4))
    //waitmovement(LOCALID_PLAYER)
    //waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    moveobjecttocoords(LOCALID_PLAYER,4,7,DIR_EAST)
    moveobjecttocoords(LOCALID_MERMEREZA_GYM_BELEN,9,7,DIR_WEST)
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    waitmovement(LOCALID_PLAYER)
    goto(EnterBelen_Intro_Dialogue)
}

script EnterBelen_NotReady_Dialogue
{
    faceplayer
    if (var(VAR_GYM_1_STATE) >= MERMEREZA_GYM_PUZZLE_COMPLETE_3)
    {
        return
    }
    msgbox(format("Sorry, peque, I'm in in the middle of a seating and can only spare a moment if you've proved you can battle AND move through a kitchen."),,SPEAKER_BELEN)
    applymovement(LOCALID_MERMEREZA_GYM_BELEN,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    closemessage
    release
    end
}

script EnterBelen_Intro_Dialogue
{
  lock
  msgbox(format("Ticket said you're {PLAYER}, right? I'm Belen, head chef of Needles and the Gym Leader here."),,SPEAKER_BELEN)
  reveal(REVEAL_BELEN)
  msgbox(format("From seafood to pastries, I do it all, on top of battling! That's why I never married. Too busy striving be to the best. Let me show you the fruits of my labor! And maybe of my comiseration Razz Tart after you lose!"),,SPEAKER_BELEN,,EMOTE_HAPPY)
  startmenu_savescreen
  goto(EnterBelen_StartGymBattle_Script)
}

script EnterBelen_StartGymBattle_Script
{
    lock
    faceplayer
    msgbox(format("I think you talk more about food than you do battling..."),,SPEAKER_ALICIA,,EMOTE_SWEAT)
    closemessage
    trainerbattle_no_intro(TRAINER_BELEN,format("Woah, super sour! I'll add some Micle Berry."))
    goto(EnterBelen_BelenDefeated_Script)
}

script EnterBelen_BelenDefeated_Script
{
    lockall
    setflag(FLAG_BADGE01_GET)
    setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_DEFEATED_LEADER)
    addvar(VAR_STORYLINE_STATE, 1)
    call(WowYoureStrong_CheckCutsceneScript)
    msgbox(format("That was delicious! I'm absolutely satiated."),,SPEAKER_BELEN)
    closemessage
    special(GetNumberOfBadges)
    call_if_eq(VAR_RESULT,1,EnterBelen_ExplainBuzzr_Dialogue)
    tweetfanfare(TWEET_GYM_MERMEREZA_CITY_BADGE,MUS_OBTAIN_BADGE)
    giveitem(ITEM_TM01)
    msgbox(format("Oh, the food!"),,SPEAKER_BELEN)
    closemessage
    moveobjecttocoords(LOCALID_MERMEREZA_GYM_BELEN,8,2,DIR_NORTH)
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    setvar(VAR_TEMP_0,0)
    call(TryAutoSave)
    call(AaandWereBack_Monologue)
    releaseall
    end
}

script EnterBelen_ExplainBuzzr_Dialogue
{
    msgbox(format("I'll serve up that tweet now!"),,SPEAKER_BELEN)
    msgbox(format("What's a tweet?"),,SPEAKER_ALICIA)
    msgbox(format("You haven't tasted the wonders of Buzzr?"),,SPEAKER_BELEN)
    msgbox(format("Everybody in the region uses the app! You can send messages and post updates about your world. In the SharpRise Capital League, when you defeat a Gym Leader, we celebrate with a post on Buzzr! When all the leaders have posted about you, you've qualified for the Championship."),,SPEAKER_BELEN)
    call(EnterBelen_DownloadBuzzr_Dialogue)
    closemessage
}

script EnterBelen_DownloadBuzzr_Dialogue
{
    msgbox(format("Let me download it real quick..."),,SPEAKER_ALICIA)
        closemessage
        fadescreen(FADE_TO_BLACK)
        call(EventScript_InstallBuzzrApp)
        fadescreen(FADE_FROM_BLACK)
        return

}

script EnterBelen_PostDefeat1_Dialogue {
  lockall
  setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_EXPLAIN_BADGE)
    bufferitemname(STR_VAR_1,ITEM_TM01)
    buffermovename(STR_VAR_2,MOVE_FLAMETHROWER)
  msgbox(format("{STR_VAR_1} has one of my most delicious moves, it allows your Pokémon to use {STR_VAR_2}."),MSGBOX_NPC,SPEAKER_BELEN)
      applymovement(LOCALID_MERMEREZA_GYM_BELEN,Common_Movement_FaceUp)
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
  closemessage
  releaseall
  end
}

script EnterBelen_PostDefeat2_Dialogue {
  lockall
  msgbox(format("Let's cook together again soon! Now if you'll excuse me..."),,SPEAKER_BELEN)
    closemessage
  releaseall
  end
}

