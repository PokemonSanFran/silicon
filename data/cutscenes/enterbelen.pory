    applymovement(LOCALID_MERMEREZA_GYM_3_7, moves(walk_left * 3, walk_up, face_left, delay_16 * 6, walk_fast_down, walk_fast_left * 5, walk_left * 2, walk_right, jump_in_place_down_up, walk_left * 2, walk_fast_up * 3, walk_fast_right * 2, walk_fast_up * 2, emote_question_mark, delay_16 * 2, walk_right, walk_up * 3, walk_fast_left * 3, walk_fast_down, face_right))
    applymovement(LOCALID_MERMEREZA_GYM_3_8, moves(walk_fast_left * 3, walk_fast_up * 2, emote_exclamation_mark, walk_right * 3, walk_up * 3, walk_left * 2, walk_fast_left * 3, walk_fast_down * 4, jump_in_place_left_right, walk_fast_left, jump_in_place_up_down, delay_16 * 4, walk_fast_up * 2, walk_left, walk_up, face_left))
    applymovement(LOCALID_MERMEREZA_GYM_3_9, moves(walk_left * 3, face_down, delay_16 * 5, walk_fast_right * 3, walk_fast_up, walk_fast_right * 3, walk_up * 3, walk_left * 2, walk_up, walk_fast_right * 5, walk_down * 5, emote_question_mark, delay_16 * 5, walk_fast_down * 2, face_left))
    applymovement(LOCALID_MERMEREZA_GYM_3_10, moves(walk_fast_right, walk_fast_up, walk_left * 4, jump_in_place_right_left, walk_fast_down, walk_fast_right * 7, walk_fast_down, walk_right, walk_down * 2, walk_right * 2, emote_exclamation_mark, delay_16 * 3, walk_fast_down * 2, walk_fast_right * 3, walk_fast_up * 4, face_left, delay_16 * 5, walk_down, walk_up * 3, walk_fast_left, face_left))
    applymovement(LOCALID_MERMEREZA_GYM_3_11, moves(emote_double_exclamation_mark, walk_right * 2, face_up, jump_in_place_down_up, jump_in_place_right_left, face_up, delay_16 * 8, walk_left * 3, walk_up, face_right, emote_question_mark, delay_16 * 5, walk_down, walk_right, face_up))

    waitmovement(LOCALID_MERMEREZA_GYM_3_1)
