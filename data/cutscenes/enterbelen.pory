script EnterBelen_Script_EnterRoom1
{
    addvar(VAR_MERMEREZAGYM_EXPLAIN_PUZZLE,1)
    if (var(VAR_GYM_1_STATE) >= MERMEREZA_GYM_PUZZLE_COMPLETE_1)
    {
        return
    }
    applymovement(LOCALID_PLAYER,Common_Movement_FaceRight)
    waitmovement(LOCALID_PLAYER)
    goto(EnterBelen_Dialogue_StartPuzzle1)
}

