script EnterBelen_Script_StartPuzzle2
{
    msgbox(format("You need to defeat the Gym Trainer, who is here -"),,SPEAKER_MERMEREZAGYMSERVERB)
    closemessage
    applymovement(LOCALID_MERMEREZA_GYM_2_4,moves(jump_in_place_up * 2))
    playse(SE_BIKE_HOP)
    waitse
    playse(SE_BIKE_HOP)
    waitse
    waitmovement(LOCALID_MERMEREZA_GYM_2_4)
    msgbox(format("- so just talk to them to battle them!"),,SPEAKER_MERMEREZAGYMSERVERB)
    waitmessage
    closemessage
        applymovement(LOCALID_MERMEREZA_GYM_2_1, moves(face_down, walk_in_place_down * 3, walk_right * 4, walk_down, face_right, delay_16, walk_left * 2, walk_down * 5, face_left, walk_in_place_left * 5, walk_up * 5, face_left))
        applymovement(LOCALID_MERMEREZA_GYM_2_2, moves(walk_up, walk_left, face_down, delay_16, walk_right, walk_down * 5, walk_right * 4, walk_in_place_down * 3, walk_right, walk_down * 3, walk_left * 2, face_up, delay_16))
        applymovement(LOCALID_MERMEREZA_GYM_2_3, moves(walk_down * 2, walk_left, walk_in_place_up * 3, walk_left * 2, walk_up, walk_left * 2, delay_16 * 2, walk_down, walk_left * 2, face_up, face_down, jump_in_place_down, walk_left, walk_down * 4, face_right))
        applymovement(LOCALID_MERMEREZA_GYM_2_4, moves(walk_down * 2, jump_in_place_down * 2, walk_left, face_down, delay_16, walk_left, walk_down * 3, walk_right * 2, face_up, delay_16 * 2, walk_left * 6, emote_exclamation_mark, walk_right * 2, walk_up, face_left))
        applymovement(LOCALID_MERMEREZA_GYM_2_5, moves(walk_left * 2, walk_up * 2, face_right, jump_in_place_right_left * 2, walk_left * 2, walk_up * 2, face_right, face_left, walk_left * 2, walk_up, walk_left, walk_up * 2, emote_question_mark, face_right, walk_up, walk_right * 6, face_down))
        applymovement(LOCALID_MERMEREZA_GYM_2_6, moves(walk_up * 3, jump_in_place_up * 2, walk_up * 4, walk_right, face_down, delay_16 * 2, walk_right * 2, walk_down * 3, walk_left, face_up, emote_exclamation_mark, walk_left * 1, walk_down * 2, walk_left * 3, walk_down, walk_right * 2, emote_exclamation_mark, walk_down, face_right))
        applymovement(LOCALID_MERMEREZA_GYM_2_7, moves(walk_down, walk_right * 3, walk_up * 2, face_right, face_left, delay_16 * 2, walk_up, walk_left * 3, walk_down * 2, emote_exclamation_mark, jump_in_place_down_up, walk_up * 4, walk_right * 5, walk_up, face_right, delay_16 * 2, walk_left * 2))
        applymovement(LOCALID_MERMEREZA_GYM_2_8, moves(emote_exclamation_mark, walk_right, face_down, emote_question_mark, walk_up * 2, walk_right * 3, walk_down * 3, face_right, delay_16 * 4, walk_up * 3, walk_right * 3, walk_up * 2, face_left, jump_in_place_left_right * 2, walk_down * 5, face_left))
        waitmovement(LOCALID_MERMEREZA_GYM_2_1)
        waitmovement(LOCALID_MERMEREZA_GYM_2_2)
        waitmovement(LOCALID_MERMEREZA_GYM_2_3)
        waitmovement(LOCALID_MERMEREZA_GYM_2_4)
        waitmovement(LOCALID_MERMEREZA_GYM_2_5)
        waitmovement(LOCALID_MERMEREZA_GYM_2_6)
        waitmovement(LOCALID_MERMEREZA_GYM_2_7)
        waitmovement(LOCALID_MERMEREZA_GYM_2_8)
        release
        end
}

