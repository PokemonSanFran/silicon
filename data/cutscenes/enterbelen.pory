const BELEN = LOCALID_MERMEREZA_GYM_BELEN
const VAR_MERMEREZAGYM_EXPLAIN_PUZZLE = VAR_TEMP_8

script EnterBelen_StartGymBattle_ObjectSetup_Script
{
    if (var (VAR_GYM_1_STATE) != MERMEREZA_GYM_SAVE_BEFORE_LEADER)
    {
        return
    }
    setobjectxyperm(LOCALID_MERMEREZA_GYM_BELEN, 6, 5)
    setobjectmovementtype(LOCALID_MERMEREZA_GYM_BELEN, MOVEMENT_TYPE_FACE_LEFT)
}

script EnterBelen_Script_InteractHost
{
    lock
    faceplayer
    call_if_quest_complete(QUEST_RESTAURANTEXPANSION2,EnterBelen_Dialogue_ExplainBelenRematch)
    call_if_quest_active(QUEST_RESTAURANTEXPANSION1,EnterBelen_Dialogue_ExplainFlowers)
    call_if_set(FLAG_BADGE01_GET,EnterBelen_Dialogue_HintBelenLocation)
    call_if_ge(VAR_GYM_1_STATE,MERMEREZA_GYM_INTRODUCED,EnterBelen_Dialogue_ExplainGym)
    call(EnterBelen_Dialogue_FirstIntroGym)
}

script EnterBelen_Dialogue_FirstIntroGym
{
    lock
    faceplayer
    setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_INTRODUCED)
    msgbox(format("Welcome to Needles! Do you have a reservation for just one today?"),,SPEAKER_MERMEREZAGYMHOST)
    msgbox(format("I'm not eating, I was looking for the Pokemon Lea -"),,SPEAKER_ALICIA)
    closemessage

    applymovement(LOCALID_MERMEREZAGYMHOST,moves(face_up))
    waitmovement(LOCALID_MERMEREZAGYMHOST)
    msgbox(format("One challenger!"),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    applymovement(LOCALID_MERMEREZA_GYM_BELEN,moves(face_up))
    waitmovement(LOCALID_MERMEREZA_GYM_BELEN)
    msgbox(format("Heard!"),,SPEAKER_BELEN)
    closemessage

    applymovement(LOCALID_MERMEREZAGYMHOST,moves(face_down))
    waitmovement(LOCALID_MERMEREZAGYMHOST)
    msgbox(format("Okay okay, challenger {PLAYER}! We've been expecting you."),,SPEAKER_MERMEREZAGYMHOST)
    msgbox(format("Behind me is the entrance to the kitchen. You'll have to defeat Belen's Gym Trainers to prove you're ready for the main dish."),,SPEAKER_MERMEREZAGYMHOST)
    goto(EnterBelen_Dialogue_HowDefeatBelen)
}

script EnterBelen_Dialogue_ExplainGym
{
    buffermapname(STR_VAR_1,MAP_MERMEREZA_CITY_GYM)
    msgbox(format("Belen is the owner and head chef of Needles. She's also the Gym Leader of the {STR_VAR_1} Gym!"),,SPEAKER_MERMEREZAGYMHOST)
    goto(EnterBelen_Dialogue_HowDefeatBelen)
}

script EnterBelen_Dialogue_HowDefeatBelen
{
    msgbox(format("Here at Mermereza Gym we pride ourselves on being resourceful. We’re all about using held items and berries in battle!"),,SPEAKER_MERMEREZAGYMHOST)
    msgbox(format("Some trainers who have beaten Belen in the past have been able to ensure her Pokemon can’t use their held items."),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    release
    end
}

script EnterBelen_Dialogue_HintBelenLocation
{
    buffermapname(STR_VAR_1,MAP_OROLAND)
    msgbox(format("You beat Belen? Congratulations! You may be the most resourceful one in the room!"),,SPEAKER_MERMEREZAGYMHOST)
    msgbox(format("Sometimes, Belen is seen around the region trying new restaurants. I think there's something new opening in {STR_VAR_1} soon..."),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    release
    end
}

script EnterBelen_Dialogue_ExplainFlowers
{
    msgbox(format("Belen's new restaurant certainly sounds interesting! I'm excited to see how it goes."),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    release
    end
}

script EnterBelen_Dialogue_ExplainBelenRematch
{
    msgbox(format("Welcome back! Gym Leader Belen has been cooking up something fierce. Are you ready for a taste?"),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    release
    end
}

script EnterBelen_Script_ResetPuzzle1
{
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_MERMEREZA_GYM_1_1)
    removeobject(LOCALID_MERMEREZA_GYM_1_2)
    removeobject(LOCALID_MERMEREZA_GYM_1_3)
    removeobject(LOCALID_MERMEREZA_GYM_1_4)
    addobject(LOCALID_MERMEREZA_GYM_1_1)
    addobject(LOCALID_MERMEREZA_GYM_1_2)
    addobject(LOCALID_MERMEREZA_GYM_1_3)
    addobject(LOCALID_MERMEREZA_GYM_1_4)
    applymovement(LOCALID_PLAYER,Common_Movement_FaceUp)
    setobjectxy(LOCALID_PLAYER,6,9)
    TeleportCamera(6,9)
    fadescreen(FADE_FROM_BLACK)
}

