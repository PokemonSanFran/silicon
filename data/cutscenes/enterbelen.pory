script EnterBelen_Script_InteractPuzzle1
{
    lock
    faceplayer
    goto(EnterBelen_Dialogue_StartPuzzle1)
}

script EnterBelen_Dialogue_StartPuzzle1
{
    if (var(VAR_GYM_1_STATE) >= MERMEREZA_GYM_PUZZLE_COMPLETE_1)
    {
        msgbox(format("Good luck on the Line!"),,SPEAKER_MERMEREZAGYMSERVERA)
        closemessage
        release
        end
    }
    elif (var(VAR_GYM_1_STATE) == MERMEREZA_GYM_PUZZLE_EXPLAINED_1)
    {
        call(EnterBelen_Script_ResetPuzzle1)
        goto(EnterBelen_Script_StartPuzzle1)
    }
    else
    {
        goto(EnterBelen_Script_ExplainPuzzle1)
    }
}

script EnterBelen_Script_ExplainPuzzle1
{
    setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_PUZZLE_EXPLAINED_1)
    msgbox(format("In the Needles Expo Room, our staff performs a final check on every single dish leaving the kitchen to make sure they live up to Belen's high standards."),,SPEAKER_MERMEREZAGYMSERVERA)
    msgbox(format("It can be very hectic at times!"),,SPEAKER_MERMEREZAGYMSERVERA)
    goto(EnterBelen_Script_StartPuzzle1)
}

script EnterBelen_Script_StartPuzzle1
{
    msgbox(format(" Our Gym Trainer is here -"),,SPEAKER_MERMEREZAGYMSERVERA)
    waitmessage
    closemessage
    special(SpawnCameraObject)
    applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_up * 3))
    waitmovement(OBJ_EVENT_ID_CAMERA)
    special(RemoveCameraObject)
    applymovement(LOCALID_MERMEREZA_GYM_1_3,moves(jump_in_place_down * 2))
    playse(SE_BIKE_HOP)
    waitse
    playse(SE_BIKE_HOP)
    waitse
    waitmovement(LOCALID_MERMEREZA_GYM_1_3)
    msgbox(format("- so just talk to them to battle them!"),,SPEAKER_MERMEREZAGYMSERVERA)
    waitmessage
    closemessage

    applymovement(LOCALID_MERMEREZA_GYM_1_1, moves(walk_right * 2, walk_left, walk_right, walk_down * 3, walk_right * 4, walk_up * 3, walk_left * 3, walk_down * 3, walk_left * 3, face_up))
    applymovement(LOCALID_MERMEREZA_GYM_1_2,     moves(walk_left, walk_right * 2, walk_up * 3, walk_left * 3, walk_down * 3, walk_left, walk_up * 2, walk_right, walk_down * 2, walk_right, face_up)
)
    applymovement(LOCALID_MERMEREZA_GYM_1_3, moves(walk_left, walk_down * 3, walk_left * 4, walk_up * 3, walk_right * 3, walk_down * 3, walk_up * 3, walk_right * 2, face_down))
    applymovement(LOCALID_MERMEREZA_GYM_1_4, moves(walk_right, walk_up * 3, walk_right, walk_down * 3, walk_right * 3, walk_up * 3, walk_left * 6, face_down))
    waitmovement(LOCALID_MERMEREZA_GYM_1_1)
    waitmovement(LOCALID_MERMEREZA_GYM_1_2)
    waitmovement(LOCALID_MERMEREZA_GYM_1_3)
    waitmovement(LOCALID_MERMEREZA_GYM_1_4)
    special(SpawnCameraObject)
    applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_down * 3))
    waitmovement(OBJ_EVENT_ID_CAMERA)
    special(RemoveCameraObject)
    msgbox(format("But don't disturb our other staff!"),,SPEAKER_MERMEREZAGYMSERVERA)
    closemessage
    release
    end
}

