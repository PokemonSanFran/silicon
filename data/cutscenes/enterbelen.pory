script EnterBelen_Dialgoue_BlockProgressFrom1
{
    lock
    if (var(VAR_GYM_1_STATE) >= MERMEREZA_GYM_PUZZLE_COMPLETE_1)
    {
        addvar(VAR_TEMP_B,1)
    }
    else
    {
        msgbox(format("I need to find the Gym Trainer in the Expo Room first!"),,SPEAKER_ALICIA,TAIL_THOUGHT)
        closemessage
        moveobjecttocoords(LOCALID_PLAYER,2,5,DIR_EAST)
    waitmovement(LOCALID_PLAYER)
    }
    release
    end
}

