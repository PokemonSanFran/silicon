script EnterBelen_Script_StartGymTrainerBattle1
{
    // PSF TODO Replace with TRAINER_032E8AC9
    buffermovename(STR_VAR_1,MOVE_FLING)
    trainerbattle_single(TRAINER_CHEFA,format("Gotta be prepared to catch whatever the Line happens to {STR_VAR_1} at you!"),format("You caught that way better than I would..."),EnterBelen_Script_StartGymTrainerBattle1)
    if (var(VAR_GYM_1_STATE) < MERMEREZA_GYM_PUZZLE_COMPLETE_1)
    {
        setvar(VAR_GYM_1_STATE,MERMEREZA_GYM_PUZZLE_COMPLETE_1)
    }
    msgbox(format("You have to beat two more Gym Trainers before you can challenge Belen. The Line is way more difficult than this room!"),MSGBOX_NPC,SPEAKER_032E8AC9)
}

script EnterBelen_Script_StartGymTrainerBattle2
