script Manhunt_TransformTreestoTallGrass
{
    setmetatile(24,29,0x015,FALSE)
    setmetatile(24,28,0x015,FALSE)
    setmetatile(24,27,0x015,FALSE)
    setmetatile(24,26,0x015,FALSE)
}
//Route98
script Manhunt_Dialogue_Matthew
{
    goto_if_ge(VAR_MANHUNT_STATE,MANHUNT_COMPLETE,Manhunt_Dialogue_MatthewQuestCompleteWrapper)
    goto_if_ge(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_4,Manhunt_Dialogue_MatthewRepeatHintWrapper)
    goto_if_eq(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_3,Manhunt_Matthew_Battle_Script)
    return
}

script Manhunt_Matthew_Battle_Script
{
    lock
    spawnobject(OBJ_EVENT_GFX_CHARLOTTE,LOCALID_MANHUNT_CHARLOTTE,24,29,MOVEMENT_TYPE_FACE_DOWN)
    call(Manhunt_TransformTreestoTallGrass)
    moveobjecttocoords(LOCALID_PLAYER,22,22,DIR_EAST)
    delay(32)
    moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,24,22,DIR_WEST)
    waitmovement(LOCALID_PLAYER)
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    msgbox(format("Oh damn, looks like they were right."),,SPEAKER_MATTHEW)
    msgbox(format("Who's they?"),,SPEAKER_ALICIA)
    msgbox(format("Yeah, Vigrim told me you'd be coming. But I wonder how tough you actually are!"),,SPEAKER_MATTHEW)
    msgbox(format("Look, we don't have to fight, but you need to tell us -"),,SPEAKER_ALICIA)
    msgbox(format("Ignore {POSSESSIVE} good cop routine."),,SPEAKER_CHARLOTTE_SHARPRISE)
    msgbox(format("This isn't a bit - I'm serious!"),,SPEAKER_ALICIA,TAIL_SHOUT)
    msgbox(format("When dealing with terrorists, I prefer bad cop, worse cop."),,SPEAKER_CHARLOTTE_SHARPRISE)
    msgbox(format("Guess which one I am?"),,SPEAKER_CHARLOTTE_SHARPRISE,,EMOTE_LAUGH)
    closemessage
    goto(Manhunt_StartBattle4_Script)
}

script Manhunt_StartBattle4_Script
{
    multi_2_vs_1(TRAINER_QUEST_MANHUNT_CIVILIAN_4,format("Oh damn, looks like they were right."),PARTNER_CHARLOTTE)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    setflag(TRAINER_FLAGS_START + TRAINER_QUEST_MANHUNT_CIVILIAN_4)
    setvar(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_4)
    startcutscene(JUMPPLAYER_MANHUNT_ROUTE)

    msgbox(format("You're no joke."),,SPEAKER_MATTHEW)
    call(Manhunt_Dialogue_MatthewRepeatHint)
    msgbox(format("They're tired of you hurting people just to track them down, and I agree…"),,SPEAKER_MATTHEW)
    closemessage

    applymovement(LOCALID_ROUTE98_MATTHEW,Common_Movement_FaceRight)
    waitmovement(LOCALID_ROUTE98_MATTHEW)
    call(Manhunt_Dialogue_MatthewQuestComplete)
    msgbox(format("…You're lucky I was raised right, or I'd spit on you too."),,SPEAKER_CHARLOTTE_SHARPRISE)
    closemessage
    moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,16,17,DIR_NORTH)
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    removeobject(LOCALID_MANHUNT_CHARLOTTE)
    call(TryAutoSave)
    endcutscene
    release
    end
}

