const PLAYER = OBJ_EVENT_ID_PLAYER
const LOCALID_MANHUNT_CHARLOTTE = LOCALID_CAMERA + 1
const LOCALID_MANHUNT_CHARLOTTE_MON = LOCALID_CAMERA + 2

script Manhunt_Script_HideRamesh
{
    setobjectflagfromlocalid(LOCALID_LEAGUEOPS_RAMESH)
}

script Manhunt_HideVigrim_Script
{
    setobjectflagfromlocalid(LOCALID_LAKE_WISHAAST_VIGRIM)
}

script Manhunt_Interact_Ramesh_Script
{
    returnqueststate(QUEST_MANHUNT)

    switch(var(VAR_RESULT))
    {
        case QUEST_MENU_SET_ACTIVE: goto(Manhunt_ActiveQuest_Dialogue)
        case QUEST_MENU_COMPLETE_QUEST: goto(Manhunt_CompleteQuest_Dialogue)
        default: goto(Manhunt_Assignment_Dialogue)
    }
}

script Manhunt_ActiveQuest_Dialogue
{
    msgbox(format("Every second that I'm up here, I'm losing time on the upcoming promo… I hope you're able to track Vigrim down soon."),MSGBOX_NPC,SPEAKER_RAMESH)
    end
}

script Manhunt_CompleteQuest_Dialogue
{
    msgbox(format("I'll be back in the Production studio if you need me."),MSGBOX_NPC,SPEAKER_RAMESH)
    end
}

script Manhunt_Assignment_Dialogue
{
    lock

        setvar(VAR_MANHUNT_STATE,ASSIGNED_FIND_VIGRIM)
        buffermapname(STR_VAR_1,MAP_OROLAND_NEWSPAPER)
        msgbox(format("Go find Vigrim. Charlotte will help. The newspaper in {STR_VAR_1} is a good place to start, they ran a story on The Tide last year."),MSGBOX_NPC,SPEAKER_RAMESH)

        call(TryAutoSave)
        startquest(QUEST_MANHUNT)
        buffermapname(STR_VAR_1,MAP_OROLAND_NEWSPAPER)
        msgbox(format("Do you want to go to {STR_VAR_1}?"),MSGBOX_YESNO)
        if (var(VAR_RESULT))
        {
            fadeblackandsetremovewarpfadeflag
            warpsilent(MAP_OROLAND,WARP_ID_OROLAND_TO_CENTER)
			waitstate
        }
    closemessage
    release
    end
}

//PerlaciaCity

script Manhunt_Dialogue_Cherie
{
    goto_if_ge(VAR_MANHUNT_STATE,MANHUNT_COMPLETE,Manhunt_Dialogue_CherieQuestComplete_Wrapper)
    goto_if_ge(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_1,Manhunt_Dialogue_CherieRepeatHintWrapper)
    goto_if_eq(VAR_MANHUNT_STATE,ASSIGNED_FIND_VIGRIM,Manhunt_Cherie_Battle_Script)
    return
}

script Manhunt_Dialogue_CherieRepeatHintWrapper
{
    lock
    faceplayer
    call(Manhunt_Dialogue_CherieRepeatHint)
    call(Manhunt_Dialogue_CherieQuestComplete)
    closemessage
    release
    end
}

script Manhunt_Dialogue_CherieRepeatHint
{
    msgbox(format("The only lead I have is a consulting firm in MermerezaCity… there's money flowing between there and The Tide, or, at least there was. I never figured out what was going on though."),,SPEAKER_CHERIE)
}

script Manhunt_Dialogue_CherieQuestComplete_Wrapper
{
    lock
    faceplayer
    call(Manhunt_Dialogue_CherieQuestComplete)
    release
    end
}

script Manhunt_Dialogue_CherieQuestComplete
{
    msgbox(format("Now please… leave us alone."),MSGBOX_AUTOCLOSE,SPEAKER_CHERIE)
    closemessage
}

script Manhunt_Cherie_Battle_Script
{
    lock
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_CHARLOTTE,LOCALID_MANHUNT_CHARLOTTE,13,3,MOVEMENT_TYPE_FACE_DOWN)
    moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,10,7,DIR_SOUTH)

    msgbox(format("Hey, we're trying to find Vigrim, and we were told you might have a connection."),MSGBOX_NPC,SPEAKER_ALICIA)
    waitse
    msgbox(format("Yeah, I wrote the The Tide leadership piece a few months back. Those youngsters were long overdue for some positive press! And getting to really sit down with Vigrim… I feel blessed to have been able to do it! "),,SPEAKER_CHERIE)

    msgbox(format("Blessed? The Tide? Ugh, they've infected you too."),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("…wait. You're that {PLAYER} kid, aren't you? "),,SPEAKER_CHERIE)

    msgbox(format("That's us."),,SPEAKER_ALICIA)

    msgbox(format("I should have recognized you two sooner. What're you doing snooping around here? Haven't you two helped enough? "),,SPEAKER_CHERIE)

    msgbox(format("Hey, we just want to talk!"),,SPEAKER_ALICIA)

    msgbox(format("As a matter of fact, get the hell out of here. Everything you two do is just hurting the region and lining the pockets of people who don't even care. Get out!"),,SPEAKER_CHERIE)
    closemessage
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    goto(Manhunt_StartBattle1_Script)
}

script Manhunt_StartBattle1_Script
{
    multi_2_vs_1(TRAINER_QUEST_MANHUNT_CIVILIAN_1,format("…Please don't hurt us any further. What do you want?"),PARTNER_CHARLOTTE)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    setvar(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_1)
    setflag(TRAINER_FLAGS_START + TRAINER_QUEST_MANHUNT_CIVILIAN_1)
    startcutscene(JUMPPLAYER_MANHUNT_NEWS)
    msgbox(format("Start talking. Who's Vigrim behind the mask?"),,SPEAKER_CHARLOTTE_SHARPRISE)

        msgbox(format("Vigrim? I swear, I don't know who she is. Nobody does. I'm a reporter… I wouldn't keep that a secret."),,SPEAKER_CHERIE)

        msgbox(format("I KNOW you know some shit."),,SPEAKER_CHARLOTTE_SHARPRISE)

        call(Manhunt_Dialogue_CherieRepeatHint)
        msgbox(format("That's a start…"),,SPEAKER_ALICIA)
        call(Manhunt_Dialogue_CherieQuestComplete)
        moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,13,2,DIR_NORTH)
        waitmovement(LOCALID_MANHUNT_CHARLOTTE)
        playse(SE_EXIT)
        removeobject(LOCALID_MANHUNT_CHARLOTTE)
        waitse
        call(TryAutoSave)
        endcutscene
        release
        end
}

//MermerezaCity

script Manhunt_Dialogue_Teodoro
{
    goto_if_ge(VAR_MANHUNT_STATE,MANHUNT_COMPLETE,Manhunt_Dialogue_TeodoroQuestCompleteWrapper)
    goto_if_ge(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_2,Manhunt_Dialogue_TeodoroRepeatHintWrapper)
    goto_if_eq(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_1,Manhunt_Teodoro_Battle_Script)
    return
}

script Manhunt_Teodoro_Battle_Script
{
    lock
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_CHARLOTTE,LOCALID_MANHUNT_CHARLOTTE,3,8,MOVEMENT_TYPE_FACE_DOWN)
    waitse
    applymovement(LOCALID_MANHUNT_CHARLOTTE, moves(walk_up * 2, jump_2_up, face_right, step_end))
    msgbox(format("What are some kids doing here?"),MSGBOX_NPC,SPEAKER_TEODORO)

    msgbox(format("You gonna make this easy? Or are you gonna keep protecting The Tide?"),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("The Tide? What the hell are you talking about? "),,SPEAKER_TEODORO)

    msgbox(format("We know you're working with The Tide, and we need to find their leader."),,SPEAKER_ALICIA)

    msgbox(format("Yeah, I did some work for them a while back. What about it? Gonna rat us out to your bosses?"),,SPEAKER_TEODORO)
    closemessage
    goto(Manhunt_StartBattle2_Script)
}
script Manhunt_StartBattle2_Script
{
    multi_2_vs_1(TRAINER_QUEST_MANHUNT_CIVILIAN_2,format("Damn punks."),PARTNER_CHARLOTTE)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    setflag(TRAINER_FLAGS_START + TRAINER_QUEST_MANHUNT_CIVILIAN_2)
    setvar(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_2)
    startcutscene(JUMPPLAYER_MANHUNT_BUSINESS)

    msgbox(format("Wow! They weren't really that strong… did Charlotte really need to go that hard?"),,SPEAKER_ALICIA,TAIL_THOUGHT,EMOTE_SHOCK)

    msgbox(format("What do you know about The Tide?"),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("Look, I don't know what you're digging for. The Tide is all above ground, nothing to hide, just trying to do some damn good in the world."),,SPEAKER_TEODORO)

    msgbox(format("If you don't start talking this is going to get very messy."),,SPEAKER_CHARLOTTE_SHARPRISE,EMOTE_ANGRY)

    msgbox(format("Wait! Okay, okay..."),,SPEAKER_TEODORO)

    call(Manhunt_Dialogue_TeodoroRepeatHint)

    msgbox(format("Let's move... Champ."),,SPEAKER_CHARLOTTE_SHARPRISE)

    call(Manhunt_Dialogue_TeodoroQuestComplete)
    applymovement(LOCALID_MANHUNT_CHARLOTTE, moves(walk_down, jump_down, walk_down * 2, step_end))
    waitmovement(0)
    playse(SE_EXIT)
    waitse
    removeobject(LOCALID_MANHUNT_CHARLOTTE)
    call(TryAutoSave)
    endcutscene
    release
    end
}


