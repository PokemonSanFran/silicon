script Manhunt_ReactAdaoraArrest_Dialogue
{
    bufferstring(STR_VAR_1,"Adaora")
    call(Manhunt_React_Dialogue)
    return
}

script Manhunt_ReactAdaoraBaiyaArrest_Dialogue
{
    bufferstring(STR_VAR_1,"Adaora and Baiya")
    call(Manhunt_React_Dialogue)
    return
}

script Manhunt_React_Dialogue
{
    msgbox(format("Your reign of terror against The Tide ends here, {PLAYER}."),MSGBOX_NPC,SPEAKER_VIGRIM)
    msgbox(format("I can't stand by and watch more innocent people get hurt while your superiors are hellbent on destroying us."),MSGBOX_NPC,SPEAKER_VIGRIM)
    msgbox(format("And then what you did to {STR_VAR_1}?"),MSGBOX_NPC,SPEAKER_VIGRIM)
    msgbox(format("No.\N{PAUSE 60}Your war ends with me."),MSGBOX_NPC,SPEAKER_VIGRIM)
    return
}

script Manhunt_Encounter_Vigrim_Dialogue
{
    lock
    faceplayer
    moveobjecttocoords(LOCALID_PLAYER,21,26,DIR_WEST)
    waitmovement(LOCALID_PLAYER)

    if(var(VAR_MANHUNT_STATE) != SAVED_BEFORE_VIGRIM)
    {
        setvar(VAR_MANHUNT_STATE,SAVED_BEFORE_VIGRIM)
        startmenu_savescreen
    }

    spawnobject(OBJ_EVENT_GFX_CHARLOTTE,LOCALID_MANHUNT_CHARLOTTE,20,33,MOVEMENT_TYPE_FACE_DOWN)
    applymovement(LOCALID_MANHUNT_CHARLOTTE, moves(walk_up * 6, step_end))
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)

    specialvar(VAR_RESULT,GetFalseTimelineCompletion)
    switch(var(VAR_RESULT))
    {
        case FALSE_TIMELINE_BURN_COMPLETE:
        case FALSE_TIMELINE_NONE_COMPLETE:
            msgbox(format("Stop hurting people. I'm here."),MSGBOX_NPC,SPEAKER_VIGRIM)

        case FALSE_TIMELINE_HOW_BURN_COMPLETE:
            call(Manhunt_ReactAdaoraBaiyaArrest_Dialogue)

        case FALSE_TIMELINE_HOW_COMPLETE:
            call(Manhunt_ReactAdaoraArrest_Dialogue)
    }
    closemessage
    goto(Manhunt_StartVigrimBattle_Script)
}

script Manhunt_StartVigrimBattle_Script
{
    multi_2_vs_1(TRAINER_VIGRIM,format("If I don't have the strength to beat you, perhaps I don't have the strength to save Resido after all."),PARTNER_CHARLOTTE)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    lock
    faceplayer
    setvar(VAR_MANHUNT_STATE,DEFEATED_MANHUNT_VIGRIM)
    addvar(VAR_STORYLINE_STATE,1)
    startcutscene(JUMPPLAYER_MANHUNT_VIGRIM)

    msgbox(format("I won't fight you any further. Call your backup."),,SPEAKER_VIGRIM,TAIL_WHISPER,EMOTE_SAD)

    specialvar(VAR_RESULT,GetFalseTimelineCompletion)
    switch(var(VAR_RESULT))
    {
        case FALSE_TIMELINE_HOW_BURN_COMPLETE:
            msgbox(format("The Tide is finished. The region is yours now."),,SPEAKER_VIGRIM)
    }

    msgbox(format("I'll call this in."),,SPEAKER_CHARLOTTE_SHARPRISE)
    closemessage
    playse(SE_POKENAV_CALL)
    waitse
    buffermapname(STR_VAR_1,MAP_WISHAAST_LAKE)
    msgbox(format("Lucrezia, I've defeated Vigrim. We'll be at the entrance to {STR_VAR_1}."),,SPEAKER_CHARLOTTE_SHARPRISE,,,PHONE_ON)

    msgbox(format("Really!? Excellent work if true. I was expecting an email, but this will do! I'll send the police right over, very well done indeed!"),,SPEAKER_LUCREZIA,,EMOTE_SHOCK,PHONE_ON)

    closemessage
    fadeblackandsetremovewarpfadeflag
    warpsilent(MAP_SHARPRISE_SPIRE_LEAGUEOPS,5,5)
    waitstate
}

script Manhunt_MissionComplete_Dialogue
{
    lock
    setvar(VAR_MANHUNT_STATE,MANHUNT_COMPLETE)

    applymovement(PLAYER,Common_Movement_FaceUp)
    applymovement(LOCALID_LEAGUEOPS_RAMESH,Common_Movement_FaceDown)
    waitmovement(LOCALID_LEAGUEOPS_RAMESH)
    waitmovement(PLAYER)

    msgbox(format("Good job, {PLAYER}. You should proud of the work you've done today."),,SPEAKER_RAMESH)

    msgbox(format("Really? I feel like proud isn't quite the right emotion - things were pretty rough out there."),,SPEAKER_ALICIA,,EMOTE_CONFUSE)

    msgbox(format("Look at this way - we can already see them scrambling on Buzzr. Without their leader it's going to be even more difficult for The Tide to mobilize any further initatives. You're making things better and that's what's important."),,SPEAKER_RAMESH,,EMOTE_HAPPY)

    specialvar(VAR_RESULT,GetFalseTimelineCompletion)
    switch(var(VAR_RESULT))
    {
        case FALSE_TIMELINE_HOW_BURN_COMPLETE:
        case FALSE_TIMELINE_HOW_COMPLETE:
            msgbox(format("Then why do I feel like I'm making things worse?"),,SPEAKER_ALICIA,TAIL_THOUGHT,EMOTE_SAD)

        case FALSE_TIMELINE_BURN_COMPLETE:
            msgbox(format("No leader and no base. Without The Tide, will things actually get better?"),,SPEAKER_PLAYER,TAIL_THOUGHT,EMOTE_CONFUSE)

        case FALSE_TIMELINE_NONE_COMPLETE:
            msgbox(format("The others won't be this bad as long as I'm not working with Charlotte again... right?"),,SPEAKER_ALICIA,TAIL_THOUGHT,EMOTE_CONFUSE)
            msgbox(format("When this is all over Resido will be a better place. It will be."),,SPEAKER_ALICIA,TAIL_THOUGHT)
    }
    closemessage

    completequest(QUEST_MANHUNT)
    call(TryAutoSave)
    endcutscene
    release
    call(ExhibitionBattle_TimeSkip_Script)
    end
}

