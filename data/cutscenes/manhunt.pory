{
    buffermapname(STR_VAR_1,MAP_IRISINA_TOWN_BALLS)
    msgbox(format("The only thing I can think of is that they buy Balls in bulk from that {STR_VAR_1} Speciality Ball Shop…"),,SPEAKER_TEODORO)
}

