//IrisinaTown_Balls
script Manhunt_Dialogue_Dudley
{
    goto_if_ge(VAR_MANHUNT_STATE,MANHUNT_COMPLETE,Manhunt_Dialogue_DudleyQuestCompleteWrapper)
    goto_if_ge(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_3,Manhunt_Dialogue_DudleyRepeatHintWrapper)
    goto_if_eq(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_2,Manhunt_Dudley_Battle_Script)
    return
}

script Manhunt_Dudley_Battle_Script
{
    lock
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_CHARLOTTE,LOCALID_MANHUNT_CHARLOTTE,8,2,MOVEMENT_TYPE_FACE_DOWN)
    moveobjecttocoords(LOCALID_PLAYER,6,6,DIR_NORTH)
    delay(16)
    moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,6,4,DIR_SOUTH)
    waitse
    waitmovement(LOCALID_PLAYER)
    playse(SE_PIN)
    applymovement(LOCALID_IRISINA_BALLS_DUDLEY, moves(emote_exclamation_mark, face_up))
    waitse
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    waitmovement(LOCALID_IRISINA_BALLS_DUDLEY)

    msgbox(format("How can I help - "),,SPEAKER_DUDLEY)

    msgbox(format("Vigrim. The Tide. Tell us what you know."),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("What? The Tide? Yeah, they're one of our customers."),,SPEAKER_DUDLEY)

    msgbox(format("What are they buying in bulk from you?"),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("...\pI don't think I'm supposed to divulge that, but I can ask my boss."),,SPEAKER_DUDLEY)

    msgbox(format("Don't bother your boss. After all, he's going to have to run the shop on his own after this."),,SPEAKER_CHARLOTTE_SHARPRISE)

    msgbox(format("Whoa wait hold on!"),,SPEAKER_DUDLEY)

    msgbox(format("Charlotte, should we maybe..."),,SPEAKER_ALICIA)
    msgbox(format("What's wrong Champ, having trouble keeping up?"),,SPEAKER_CHARLOTTE_SHARPRISE,,EMOTE_LAUGH)
    closemessage
    goto(Manhunt_StartBattle3_Script)
}
script Manhunt_StartBattle3_Script
{
    multi_2_vs_1(TRAINER_QUEST_MANHUNT_CIVILIAN_3,format("Yikes!"),PARTNER_CHARLOTTE)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    setflag(TRAINER_FLAGS_START + TRAINER_QUEST_MANHUNT_CIVILIAN_3)
    setvar(VAR_MANHUNT_STATE,GOT_MANHUNT_CLUE_3)
    startcutscene(JUMPPLAYER_MANHUNT_BALL)

    msgbox(format("Shit man, I'm just doing my job!"),,SPEAKER_DUDLEY)

    msgbox(format("And we're just trying to do our job. Could you please just tell us what you know?"),,SPEAKER_ALICIA)

    msgbox(format("They bought a bunch of Dusk Balls in bulk. I don't know why, I don't know where they were going or what they were doing. "),,SPEAKER_DUDLEY)

    msgbox(format("What else! Think hard, or else."),,SPEAKER_CHARLOTTE_SHARPRISE)
    closemessage

    playse(SE_BALL_OPEN)
    callnative(Manhunt_LoadCharlotteMon)
    spawnobject(OBJ_EVENT_GFX_VAR_0,LOCALID_MANHUNT_CHARLOTTE_MON,5,5,MOVEMENT_TYPE_WALK_IN_PLACE_RIGHT)
    waitse
    callnative(Manhunt_GetCharlotteMonCry)

    msgbox(format("Woah, Charlotte, do we really need… -"),,SPEAKER_ALICIA)
    waitmoncry

    msgbox(format("I got this {PLAYER} {EMOJI_NOTE}!"),,SPEAKER_CHARLOTTE_SHARPRISE,,EMOTE_HAPPY)
    closemessage

    applymovement(LOCALID_MANHUNT_CHARLOTTE,Common_Movement_WalkInPlaceDown)
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    call(Manhunt_Dialogue_DudleyRepeatHint)
    call(Manhunt_Dialogue_DudleyQuestComplete)
    closemessage
    playse(SE_BALL_OPEN)
    removeobject(LOCALID_MANHUNT_CHARLOTTE_MON)
    waitse
    moveobjecttocoords(LOCALID_MANHUNT_CHARLOTTE,4,8,DIR_SOUTH)
    waitmovement(LOCALID_MANHUNT_CHARLOTTE)
    playse(SE_EXIT)
    removeobject(LOCALID_MANHUNT_CHARLOTTE)
    waitse
    call(TryAutoSave)
    endcutscene
    release
    end
}

