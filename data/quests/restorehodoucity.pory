script Restorehodoucity_Script_ControlPewfatVisibility
{
    callnative(Script_Quest_RestoreHodouGym_CheckIfQuestShouldStart)
    if (var(VAR_RESULT) == TRUE)
    {
        return
    }
    call(Restorehodoucity_Script_HidePewfatOutisde)
}

script Quest_Restorehodoucity_PewfatWalkInside_Script
{
    callnative(Script_Quest_RestoreHodouGym_CheckIfQuestShouldStart)
    if (var(VAR_RESULT) == FALSE)
    {
        release
        end
    }
    lock
    setvar(VAR_QUEST_RESTOREHODOUGYM,POST_PEWFAT_INTO_GYM)
    delay(15)
    opendoor(22,3)
    applymovement(LOCALID_HODOU_CITY_KEVIN,Common_Movement_WalkUp)
    applymovement(LOCALID_HODOU_CITY_ZAC, moves(walk_right, walk_up, step_end))
    waitmovement(LOCALID_HODOU_CITY_ZAC)
    playse(SE_EXIT)
    waitse
    removeobject(LOCALID_HODOU_CITY_KEVIN)
    removeobject(LOCALID_HODOU_CITY_ZAC)
    closedoor(22,3)
    waitdooranim
    startquest(QUEST_RESTOREHODOUGYM)
    setmetatile(22,3,0x2A1,FALSE)
    special(DrawWholeMapView)
    release
    end
}

script Quest_Restorehodoucity_FirstTimeInside_Dialogue
{
    lock
    playse(SE_PIN)
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(emote_exclamation_mark, face_down))
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(emote_exclamation_mark, face_down))
    waitse
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)

    msgbox(format("You’re not supposed to be here!"),,SPEAKER_KEVIN,TAIL_SHOUT,EMOTE_SHOCK)
    msgbox(format("Gym Members only!"),,SPEAKER_ZAC,TAIL_SHOUT,EMOTE_SHOCK)
    closemessage

    applymovement(LOCALID_HODOU_CITY_GYM_PKMNA,Common_Movement_WalkDown)
    applymovement(LOCALID_HODOU_CITY_GYM_PKMNB,Common_Movement_WalkDown)
    waitmovement(LOCALID_HODOU_CITY_GYM_PKMNB)
    waitmovement(LOCALID_HODOU_CITY_GYM_PKMNA)

    trainerbattle_two_trainers(TRAINER_ZAC,format("We’re too out of practice…"),TRAINER_KEVIN,(format("We’ve been found out!")))
    goto(Quest_Restorehodoucity_PostBattle_Script)
}

script Quest_Restorehodoucity_PostBattle_Script
{
    fadescreen(FADE_TO_BLACK)
    playse(SE_BALL_OPEN)
    waitse
    removeobject(LOCALID_HODOU_CITY_GYM_PKMNA)
    removeobject(LOCALID_HODOU_CITY_GYM_PKMNB)
    fadescreen(FADE_FROM_BLACK)
    setvar(VAR_QUEST_RESTOREHODOUGYM,FIND_HODOU_CITY_LEADER)
    msgbox(format("Do you guys always attack whoever walks in the door?"),,SPEAKER_PLAYER,,EMOTE_SWEAT)
    msgbox(format("It’s been 3 years since somebody else walked in that door. I didn’t even think about it, I just freaked out."),,SPEAKER_KEVIN,,EMOTE_SWEAT)
    msgbox(format("Sorry. We got spooked."),,SPEAKER_ZAC)
    msgbox(format("How did you know we’d be here?"),,SPEAKER_KEVIN)
    msgbox(format("I was sent here. Baiya -"),,SPEAKER_PLAYER)
    msgbox(format("The League runner up?"),,SPEAKER_KEVIN)
    msgbox(format("Wait, aren’t you {PLAYER}?"),,SPEAKER_ZAC)
    msgbox(format("Yeah! Baiya is working on a project to help revitalize some of the communities around the decommissioned Gyms, but it looks like you’ve already started."),,SPEAKER_PLAYER)
    msgbox(format("We just wanted somewhere to train and figured nobody would bother us here."),,SPEAKER_KEVIN)
    msgbox(format("We didn’t get any farther than that. What’s Baiya’s idea?"),,SPEAKER_ZAC)
    closemessage
    fadescreen(FADE_TO_BLACK)
    delay(16)
    fadescreen(FADE_FROM_BLACK)
    msgbox(format("That plan sounds really cool, but it’s got a few problems."),,SPEAKER_ZAC)
    msgbox(format("First is funding. The government and League aren’t going to help keep the lights on."),,SPEAKER_ZAC)
    msgbox(format("Second is leadership. We’re just two guys trying to train. I don’t think we’re the right people to help you revive the Gym."),,SPEAKER_ZAC)
    closemessage
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(face_right))
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    msgbox(format("What about Johnny?"),,SPEAKER_KEVIN)
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(face_left))
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    msgbox(format("Johnny’s just as broke as we are!"),,SPEAKER_ZAC)
    msgbox(format("But he’s obviously a leader. "),,SPEAKER_KEVIN)
    msgbox(format("Who’s Johnny?"),,SPEAKER_PLAYER)
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(face_down))
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(face_down))
    msgbox(format("Johnny is - was the deputy Gym Leader."),,SPEAKER_KEVIN)
    msgbox(format("He stopped talking to all of us after it all shut down. I think he was just too heartbroken to face us."),,SPEAKER_ZAC)
    closemessage
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(face_left))
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    msgbox(format("Maybe we can get some community fundraising going…"),,SPEAKER_ZAC)
    closemessage
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(face_right))
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    msgbox(format("To find Johnny?"),,SPEAKER_KEVIN)
    msgbox(format("No! But if {PLAYER} can find Johnny, we can focus on fundraising."),,SPEAKER_ZAC)
    msgbox(format("Oh! That’s a good idea."),,SPEAKER_KEVIN)
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(face_down))
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(face_down))
    msgbox(format("Last I heard, Johnny just sits on the beach all day. Come back here if you’re able to find him."),,SPEAKER_KEVIN)
    closemessage
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(walk_left * 1))
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(walk_right * 1))
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    release
    end
}

script Quest_Restorehodoucity_FirstJohnny_Interact_Script
{
    lock
    setvar(VAR_QUEST_RESTOREHODOUGYM,FOUND_HODOU_CITY_LEADER)
    buffermapname(STR_VAR_1,MAP_QUEST_RESTOREHODOUGYM_ORIGIN)
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_RESTOREHODOUGYM,SUB_QUEST_1)
    msgbox(format("Were you the deputy Gym Leader of {STR_VAR_1}?"),,SPEAKER_PLAYER)
    msgbox(format("How’d you know that? You don’t look like you’re from here."),,SPEAKER_JOHNNY)
    msgbox(format("Kevin and Zac sent me to find you. We’re putting a team together."),,SPEAKER_PLAYER)
    fadescreenswapbuffers(FADE_TO_BLACK)
    delay(16)
    fadescreenswapbuffers(FADE_FROM_BLACK)
    msgbox(format("Kevin and Zac? Oh yeah, those guys are going to need some help for sure."),,SPEAKER_JOHNNY,,EMOTE_LAUGH)
    msgbox(format("Some great guys, but they’re not the strategic type."),,SPEAKER_JOHNNY)
    buffermapname(STR_VAR_1,MAP_QUEST_RESTOREESPULEEGYM_ORIGIN)
    msgbox(format("I’ll meet you back in {STR_VAR_1}."),,SPEAKER_JOHNNY)
    closemessage
    moveobjecttocoords(LOCALID_CRESALTA_VISTA_JOHNNY,12,23,DIR_WEST)
    delay(8)
    fadeandremovelasttalked
    release
    end
}

script Quest_Restorehodoucity_Script_PewfatInteract
{
    lock
    if (var(VAR_QUEST_RESTOREHODOUGYM) == FIND_HODOU_CITY_LEADER)
    {
        goto(Quest_Restorehodoucity_Dialogue_PewfatWaitingJohnny)
    }
    else
    {
        goto(Quest_Restorehodoucity_Dialogue_PewfatWaitingBlackbelts)
    }
}

script Quest_Restorehodoucity_Dialogue_PewfatWaitingJohnny
{
    msgbox(format("Do you think Johnny found some money on the beach?"),,SPEAKER_KEVIN)
    msgbox(format("Oh! From like a metal detector?"),,SPEAKER_ZAC)
    msgbox(format("I don’t think money is metal!"),,SPEAKER_KEVIN)
    closemessage
    release
    end
}

script Quest_Restorehodoucity_Dialogue_PewfatWaitingBlackbelts
{
    bufferspeciesname(STR_VAR_1,SPECIES_ALCREMIE)
    msgbox(format("Okay wait, what about instead of a bake sale, we just capture a bunch of Alcremie?"),,SPEAKER_ZAC)
    msgbox(format("Do they even learn Electric-type attacks?"),,SPEAKER_KEVIN)
    buffermovename(STR_VAR_1,MOVE_FLASH)
    msgbox(format("Maybe we can teach them {STR_VAR_1}…"),,SPEAKER_ZAC)
    closemessage
    release
    end
}

script Quest_Restorehodoucity_Johnny_Interact_Script
{
    lock
    faceplayer
    goto_if_quest_complete(QUEST_RESTOREHODOUGYM,HodouCityGym_Dialogue_GreetPlayer)
    goto(Quest_Restorehodoucity_Dialogue_JohnnyWaitingBlackbelts)
}

script Quest_Restorehodoucity_Dialogue_JohnnyWaitingBlackbelts
{
    faceplayer
    msgbox(format("You’ve got the locations of the Gym Trainers, right?"),,SPEAKER_JOHNNY)
    msgbox(format("Yeah, I wrote them down in my Quest Log."),,SPEAKER_PLAYER)
    msgbox(format("Awesome. I got my hands full with these knuckleheads."),,SPEAKER_JOHNNY)
    closemessage
    applymovement(VAR_LAST_TALKED,moves(face_original_direction))
    waitmovement(VAR_LAST_TALKED)
    release
    end
}

script Quest_Restorehodoucity_FoundJohnny_Dialogue
{
    lock
    setvar(VAR_QUEST_RESTOREHODOUGYM,FIND_BLACKBELTS)
    applymovement(LOCALID_PLAYER,moves(walk_up * 2))
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,Common_Movement_FaceDown)
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,Common_Movement_FaceDown)
    waitmovement(LOCALID_PLAYER)
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    msgbox(format("Thanks for looping me in, {PLAYER}."),,SPEAKER_JOHNNY)
    msgbox(format("I can’t believe he’s back!"),,SPEAKER_KEVIN,TAIL_SHOUT,EMOTE_HAPPY)
    msgbox(format("But we didn’t find any money while you were gone."),,SPEAKER_ZAC)
    msgbox(format("{PLAYER}, the guys say you’re the new Champion? That means you’ve been all over the region. Have you seen more Trainers like us, wearing gis?"),,SPEAKER_JOHNNY)
    msgbox(format("I think so? Are all the Trainers in gis former Hodou Gym Trainers?"),,SPEAKER_PLAYER)
    msgbox(format("Just about."),,SPEAKER_ZAC,,EMOTE_SWEAT)
    msgbox(format("We have a good idea of where everybody hangs out. Since you were so good at finding Johnny, could you help us find everybody?"),,SPEAKER_KEVIN)
    msgbox(format("How many is everybody?"),,SPEAKER_PLAYER,,EMOTE_SHOCK)
    msgbox(format("Seven, I think. I’ll give you the list of locations."),,SPEAKER_JOHNNY)
    closemessage
    cueobjecttalking(LOCALID_HODOU_CITY_GYM_JOHNNY)
    msgbox(format("I’ll write these down in my Quest Log!"),,SPEAKER_PLAYER,TAIL_THOUGHT)
    msgbox(format("I’m going to keep working on building out a program here."),,SPEAKER_JOHNNY)
    msgbox(format("We’re going to host a bake sale so we can turn on the lights!"),,SPEAKER_ZAC)
    msgbox(format("I’m still confused about that. Can the lights run on cake…?"),,SPEAKER_KEVIN,,EMOTE_CONFUSE)
    closemessage
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,moves(face_left))
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,moves(face_right))
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    release
    end
}

script Quest_Restorehodoucity_Dialogue_AskAboutGym
{
  msgbox(format("Did you work at Hodou Gym? Johnny sent me to find you - he’s getting all of the old Gym Trainers together."),,SPEAKER_ALICIA)
}

