script Quest_Restorehodoucity_Reward_Dialogue
{
    setvar(VAR_QUEST_RESTOREHODOUGYM,RESTOREHODOU_CITY_COMPLETE)
    applymovement(LOCALID_PLAYER,moves(walk_up * 2))
    applymovement(LOCALID_HODOU_CITY_GYM_ZAC,Common_Movement_FaceDown)
    applymovement(LOCALID_HODOU_CITY_GYM_KEVIN,Common_Movement_FaceDown)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("Everybody’s here! This is super inspiring to get everybody back here again."),,SPEAKER_JOHNNY)
    msgbox(format("The fundraising was super easy!"),,SPEAKER_ZAC)
    msgbox(format("Turns out, you don’t need a lot of money for electricity in a single room."),,SPEAKER_KEVIN,,EMOTE_SWEAT)
    msgbox(format("I want to help Trainers keep up their momentum and drive even when their resources are totally depleted. I found this cool group online practicing battles in a unique way."),,SPEAKER_JOHNNY)
    call_if_quest_not_inactive(QUEST_COMPULSIVEHEALINGPEERSUPPORTGROUP,Restorehodoucity_Dialogue_NoPoReference)
    msgbox(format("Hopefully you come back and try it out!"),,SPEAKER_JOHNNY)
    msgbox(forma("Come talk to me or Zac when you’re ready."),,SPEAKER_KEVIN)
    closemessage
    moveobjecttocoords(LOCALID_HODOU_CITY_GYM_KEVIN,3,9,DIR_EAST)
    moveobjecttocoords(LOCALID_HODOU_CITY_GYM_ZAC,6,9,DIR_WEST)
    completequest(QUEST_RESTOREHODOUGYM)
    waitmovement(LOCALID_HODOU_CITY_GYM_KEVIN)
    waitmovement(LOCALID_HODOU_CITY_GYM_ZAC)
    release
    end
}

script Restorehodoucity_Dialogue_NoPoReference
{
    msgbox(format("Wait, is he talking about the NoPo movement? Is this actually a good idea…?"),,SPEAKER_PLAYER,TAIL_THOUGHT)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Adam
{
    msgbox(format("I can’t believe this is happening…"),MSGBOX_NPC,SPEAKER_ADAM)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Andreas
{
    msgbox(format("I’m so glad you’re working to find everybody."),MSGBOX_NPC,SPEAKER_ANDREAS)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Justin
{
    msgbox(format("Do you think Sifu Ying will also come back?"),MSGBOX_NPC,SPEAKER_JUSTIN)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Jeffrey
{
    lock
    msgbox(format("I’m so out of shape…"),,SPEAKER_JEFFREY,TAIL_WHISPER)
    msgbox(format("Man I am RARING to get back at it!"),,SPEAKER_JEFFREY)
    release
    end
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Dajuan
{
    msgbox(format("It’s so great to see Johnny working hard to revive this place."),MSGBOX_NPC,SPEAKER_DAJUAN)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Juan
{
    msgbox(format("You know, nothing was stopping us from doing this before, was there?"),MSGBOX_NPC,SPEAKER_JUAN)
}

script Quest_RestoreHodouCityGym_DialogueInsideGym_Jason
{
    msgbox(format("I could barely keep up with you, {PLAYER}. It really showed me how out of practice I am."),MSGBOX_NPC,SPEAKER_JASON)
}

