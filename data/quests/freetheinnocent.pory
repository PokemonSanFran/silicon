// Quest_Freetheinnocent

script Quest_Freetheinnocent_Dialogue_StartQuest
{
// PSF TODO FreetheinnocentcomradeA sohuld be facing a computer and always turn back to the computer when the player is done
    faceplayer
    msgbox(format("The new work that The Tide is doing is very exciting and all…But I can’t savor it if FindtheguiltyvictimB isn’t here…"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("They’re locked up for something they didn’t do!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("We were part of a club that hikes all over the region…"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("But the club HQ was broken into and a lot of expensive equipment was stolen."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("And somehow they found FindtheguiltyvictimB responsible and took him into custody."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("I don’t have any proof…But I know they’re innocent!! They’d never do anything like that!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("Please… I know there must be proof of an alibi that shows they weren’t at HQ at the time of the robbery, we just need someone to find it because the cops sure as hell won’t. "),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    call(Quest_Freetheinnocent_Dialogue_CopsEasy)
    closemessage
    startquest(QUEST_FREETHEINNOCENT)
    cueobjectplayer(LOCALID_FREETHEINNOCENTCOMRADEA)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    msgbox(format("Here. I’ve listed a bunch of places where the hikers who were out and about that day like to spend time."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    release
    end
    release
    end
}

script Quest_Freetheinnocent_Dialogue_Active
{
    faceplayer
    callnative(Script_Quest_Freetheinnocent_CashierSpoken)
    if (var(VAR_RESULT) == TRUE)
    {
        call(Quest_Freetheinnocent_Dialogue_AnyLeads)
        buffermapname(STR_VAR_1,MAP_QUEST_FREETHEINNOCENT_GYM)
        msgbox(format("The {STR_VAR_1} Gym! You should go there! Who knows what it could turn up?"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    release
    end
    }

    callnative(Script_Quest_Freetheinnocent_CupFound)
    if (var(VAR_RESULT) == TRUE)
    {
        call(Quest_Freetheinnocent_Dialogue_AnyLeads)
        msgbox(format("Hmm, perhaps going back to where this cup is from might help establish an alibi?"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    release
    end
    }

    callnative(Script_Quest_Freetheinnocent_FactsLearned)
    if (var(VAR_RESULT) == TRUE)
    {
        call(Quest_Freetheinnocent_Dialogue_AnyLeads)
        msgbox(format("It might be helpful to retrace the hikers’ journey that day from beginning to end. You might want to talk to them all to get a good sense of the journey."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    }
    else
    {
        call(Quest_Freetheinnocent_Dialogue_CopsEasy)
    }
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    release
    end
}

script Quest_Freetheinnocent_Dialogue_CopsEasy
{
    msgbox(format("I know the cops are going to take the easy way out and just convict my friend… I hope we can find something to clear their name before they’re sentenced!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
}

script Quest_Freetheinnocent_Dialogue_AnyLeads
{
    msgbox(format("You’re back! Have you uncovered any leads?"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
}

script Quest_Freetheinnocent_Dialogue_Reward
{
    faceplayer
    setflag(FLAG_TEMP_1)
    call(Quest_Freetheinnocent_Dialogue_AnyLeads)
    msgbox(format("Sharprise will have footage of the Gym battle that proves FindtheguiltyvictimB wasn’t at the scene of the crime! Think The Tide could help us get it?"),,SPEAKER_ALICIA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    msgbox(format("A gym battle? That’s huge! The Tide might already have the footage as part of a data dump they grabbed from their latest big hack!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FacePlayer)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    msgbox(format("If they do, this is surely enough evidence to free FindtheguiltyvictimB! This is wonderful!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    msgbox(format("Thank you so much! You’ve done an amazing thing today!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    closemessage
    applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    completequest(QUEST_FREETHEINNOCENT)
    release
    end
}

script Quest_Freetheinnocent_Dialogue_Complete
{
    if (flag(FLAG_TEMP_1) == TRUE)
    {
        msgbox(format("Hmm, how would I get in touch with the police department?..."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
    }
    else
    {
        faceplayer
        msgbox(format("The police actually let FindtheguiltyvictimB free!"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
        msgbox(format("They screwed this up badly but who's surprised at that?"),,SPEAKER_FREETHEINNOCENTCOMRADEA)
        msgbox(format("You did a better job at investigating than they ever could."),,SPEAKER_FREETHEINNOCENTCOMRADEA)
        applymovement(LOCALID_FREETHEINNOCENTCOMRADEA,Common_Movement_FaceOriginalDirection)
        waitmovement(LOCALID_FREETHEINNOCENTCOMRADEA)
    }
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_FreetheinnocenthikercNotComplete
{
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_FREETHEINNOCENT,SUB_QUEST_1)
    msgbox(format("Do you remember anything of interest from the hike on Thursday?"),,SPEAKER_ALICIA)
    msgbox(format("Oh, clued in on that are you?"),,SPEAKER_FREETHEINNOCENTHIKERC)
}

script Quest_Freetheinnocent_Dialogue_Freetheinnocenthikerc
{
    lock
    faceplayer
    call_if_subquest_not_complete(QUEST_FREETHEINNOCENT,SUB_QUEST_1,Quest_Freetheinnocent_Dialogue_FreetheinnocenthikercNotComplete)
    msgbox(format("Hmm…All I remember is FindtheguiltyvictimB was talking a lot…"),,SPEAKER_FREETHEINNOCENTHIKERC)
    msgbox(format("They had one of those fancy drinks that morning…A…Boba?"),,SPEAKER_FREETHEINNOCENTHIKERC)
    msgbox(format("I wish they’d been drinking more water!"),,SPEAKER_FREETHEINNOCENTHIKERC)
    msgbox(format("Still, I hope you can prove their innocence. I’d hate to believe they’d really do something like that."),,SPEAKER_FREETHEINNOCENTHIKERC)
    closemessage
    release
    end
}

