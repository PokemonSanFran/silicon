    buffermapname(STR_VAR_2,MAP_CAPHE_CITY)
    msgbox(format("I don’t remember anything peculiar. We ended at the top of {STR_VAR_1}!"),,SPEAKER_FREETHEINNOCENTHIKERG)
    msgbox(format("I went to my favorite coffee spot in {STR_VAR_2}, too."),,SPEAKER_FREETHEINNOCENTHIKERG)
    msgbox(format("If there’s anything fishy going on, I hope you get to the bottom of it."),,SPEAKER_FREETHEINNOCENTHIKERG)
    closemessage
    release
    end
}

