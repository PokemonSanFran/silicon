    msgbox(format("We had to urgently stop in {STR_VAR_1} halfway through, but that’s normal. Sometimes people have trash they need to dispose of, and I really needed to use the restroom!"),,SPEAKER_FREETHEINNOCENTHIKERD)
    msgbox(format("I hope FindtheguiltyvictimB is innocent…"),,SPEAKER_FREETHEINNOCENTHIKERD)
