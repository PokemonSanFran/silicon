{
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_FREETHEINNOCENT,SUB_QUEST_5)
    msgbox(format("The day the clubhouse was stolen from - remember anything weird from it?"),,SPEAKER_ALICIA)
