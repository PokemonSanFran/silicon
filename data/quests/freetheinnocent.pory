script Quest_Freetheinnocent_Dialogue_Findtheguiltyplanth
{
    lock
    faceplayer
    call_if_subquest_not_complete(QUEST_FREETHEINNOCENT,SUB_QUEST_5,Quest_Freetheinnocent_Dialogue_FindtheguiltyplanthNotComplete)
    msgbox(format("Don’t remember anything weird from that one hike!"),,SPEAKER_FINDTHEGUILTYPLANTH)
    msgbox(format("I just remember FindtheguiltyvictimB havin’ a boba and seeming really fired up!"),,SPEAKER_FINDTHEGUILTYPLANTH)
    msgbox(format("He might have been overcompensating, considering he robbed the club."),,SPEAKER_FINDTHEGUILTYPLANTH)
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_Trashcan
{
    msgbox(format("Hey! There’s an empty boba cup with FindtheguiltyvictimB’s name on it!"),,SPEAKER_ALICIA,TAIL_THOUGHT,EMOTE_SHOCK)
    closemessage
    checkitemspace(ITEM_QUEST_FREETHEINNOCENT_BOBA,1)
    if (var(VAR_RESULT))
    {
        subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_FREETHEINNOCENT,SUB_QUEST_6)
        giveitem(ITEM_QUEST_FREETHEINNOCENT_BOBA,1)
        buffermapname(STR_VAR_1,MAP_CRESALTA_VISTA_GEMHOUSE)
        msgbox(format("Hmm…{STR_VAR_1} Boba…Maybe I should check in."),,SPEAKER_ALICIA,TAIL_THOUGHT,EMOTE_SHOCK)
    }
    else
    {
        msgbox(format("I don’t have space…One sec."),,SPEAKER_ALICIA,TAIL_THOUGHT)
    }
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_FreetheinnocentbobacashieriComplete
{
    msgbox(format("I’m glad you found what you were looking for! And with clean hands no less!"),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_FreetheinnocentbobacashieriActive
{
    callnative(Script_Quest_Freetheinnocent_CashierSpoken)
    if (var(VAR_RESULT))
    {
        msgbox(format("I wish you luck with whatever you’re after, but for your own sake, stop digging around in the trash!"),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
        closemessage
        release
        end
    }

    callnative(Script_Quest_Freetheinnocent_CupFound)
    if (var(VAR_RESULT))
    {
        subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_FREETHEINNOCENT,SUB_QUEST_7)
        removeitem(ITEM_QUEST_FREETHEINNOCENT_BOBA,1)
        bufferitemnameplural(STR_VAR_2,ITEM_SPIKED_CONCHA,2)
        bufferitemnameplural(STR_VAR_3,ITEM_SPIKED_CONCHA,1)
        msgbox(format("Welcome in! How can I help you, young one?"),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
        closemessage
        cueobject(LOCALID_PLAYER,DIR_FACING)
        msgbox(format("Here. Can you look up the order number on this cup and tell me when this person was last here?"),,SPEAKER_ALICIA)
        msgbox(format("Did you…Fetch this from the trash? How…Peculiar…"),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
        msgbox(format("Well if you must know, the order time is on the cup, and it says 12pm."),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
        msgbox(format("{STR_VAR_2}…Yes, I remember this guy! They had a {STR_VAR_3}…and got their crumbs everywhere!"),,SPEAKER_FREETHEINNOCENTBOBACASHIERI)
        buffermapname(STR_VAR_1,MAP_QUEST_FREETHEINNOCENT_GYM)
        msgbox(format("{STR_VAR_2}…I think that’s a {STR_VAR_1} Gym thing…"),,SPEAKER_ALICIA)
        goto(Quest_Freetheinnocent_Dialogue_FreetheinnocentbobacashieriActive)
    }
    else
    {
        return
    }
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_HostActive
{
    questmenu(QUEST_MENU_SET_REWARD,QUEST_FREETHEINNOCENT)
    msgbox(format("Say, have you ever heard of a Trainer named FindtheguiltyvictimB?"),,SPEAKER_ALICIA)
    msgbox(format("I have! But only because I seem to recall them beating Belen recently…"),,SPEAKER_MERMEREZAGYMHOST)
    msgbox(format("Is there any way to prove that they were here?"),,SPEAKER_ALICIA)
    msgbox(format("Sharprise uses all the footage from gym battles for online content. It should have times and dates attached to it."),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    playse(SE_PIN)
    applymovement(LOCALID_PLAYER,Common_Movement_ExclamationMark)
    waitmovement(LOCALID_PLAYER)
    waitse
    msgbox(format("Sharprise surely won’t just give it up, but maybe The Tide could help me get it?..."),,SPEAKER_ALICIA,TAIL_WHISPER,EMOTE_SHOCK)
    msgbox(format("Thank you! You’ve been a great help!"),,SPEAKER_ALICIA)
    closemessage
    release
    end
}

script Quest_Freetheinnocent_Dialogue_HostReward
{
    msgbox(format("Hey there! Were you able to help your friend in the end? Your situation sounded pretty serious if you don’t mind my saying."),,SPEAKER_MERMEREZAGYMHOST)
    closemessage
    release
    end
}
