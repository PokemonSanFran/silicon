//Improvbattling_Script_
//Improvbattling_Dialogue_

script Improvbattling_Script_CheckQuestAndHideTroupe
{
    callnative(Script_Improvbattling_ShouldLeaderMoveOffStage)
    call_if_eq(VAR_RESULT,TRUE,Improvbattling_Script_MoveTroupeA)
}

script Improvbattling_Script_MoveTroupeA
{
    setobjectxyperm(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,4,4)
}

script Improvbattling_Script_HideNewImprovtroupe
{
    setobjectflagfromlocalid(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX)
    setobjectflagfromlocalid(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY)
    setobjectflagfromlocalid(LOCALID_PETAROSA_THEATER_IMPROVTROUPEZ)
}

script Improvbattling_Dialogue_ImprovaudienceD
{
    lock
    faceplayer
    msgbox(format(""),,SPEAKER_IMPROVAUDIENCED)
    closemessage
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCED,moves(face_original_direction))
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCED)
    end
}

script Improvbattling_Dialogue_ImprovaudienceE
{
    lock
    faceplayer
    msgbox(format(""),,SPEAKER_IMPROVAUDIENCEE)
    closemessage
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEE,moves(face_original_direction))
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEE)
    end
}

script Improvbattling_Dialogue_ImprovaudienceF
{
    lock
    faceplayer
    msgbox(format("I’m the founder of this place. Before Sharp Rise took over the League, alternative battling styles were way more popular. It’s getting harder and harder to keep the lights on as fewer people come out to these."),,SPEAKER_IMPROVAUDIENCEF)
    closemessage
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEF,moves(face_original_direction))
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEF)
    end
}

script Improvbattling_Dialogue_ImprovaudienceG
{
    lock
    faceplayer
    msgbox(format("The improv actors here are all early in the careers, but all want to break into acting full time."),,SPEAKER_IMPROVAUDIENCEG)
    msgbox(format("I hope they get the chance!"),,SPEAKER_IMPROVAUDIENCEG)
    closemessage
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEG,moves(face_original_direction))
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEG)
    release
    end
}

script Improvbattling_Dialogue_ImprovaudienceH
{
    lock
    faceplayer
    msgbox(format(""),,SPEAKER_IMPROVAUDIENCEH)
    closemessage
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEH,moves(face_original_direction))
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVAUDIENCEH)
    end
}

script Improvbattling_Script_RoutePlayer
{
    goto_if_subquest_complete(QUEST_RESTOREZENZUGYM,SUB_QUEST_3,Improvbattling_Script_PostQuestChallenge_PostRecruit)
    goto_if_quest_complete(QUEST_IMPROVBATTLING,Improvbattling_Script_PostQuestChallenge)
    goto_if_quest_active(QUEST_IMPROVBATTLING,Improvbattling_Script_ContinueChallenge)
    goto_if_quest_not_active(QUEST_IMPROVBATTLING,Improvbattling_Script_StartQuest)
}

script Improvbattling_Script_StartQuest
{
    lock
    msgbox(format("And now we need somebody brave from the audience!"),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Seems we have a volunteer already!"),,SPEAKER_IMPROVTROUPEB)
    closemessage
    msgbox(format("Wait no, I"),,SPEAKER_PLAYER,,EMOTE_SHOCK)
    msgbox(format("Rules are rules, and the first rule of improv is to always “yes, and”! Come on up here!"),,SPEAKER_IMPROVTROUPEC)
    call(Improvbattling_Script_MovePlayerToStage)
    msgbox(format("Okay talk into the mic."),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Tell everybody your name, and where you’re from!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    applymovement(LOCALID_PLAYER,moves(face_down))
    waitmovement(LOCALID_PLAYER)
    msgbox(format("I'm {PLAYER}, and I'm from Agate Village, Orre."),,SPEAKER_PLAYER)
    msgbox(format("You look tough {PLAYER}. Have you battled before?"),,SPEAKER_IMPROVTROUPEA)
    call(Improvbattling_Dialogue_ChangeDialogueBasedOnProgress)
    startquest(QUEST_IMPROVBATTLING)
    goto(Improvbattling_Script_StartSwapEvent)
}

script Improvbattling_Dialogue_ChangeDialogueBasedOnProgress
{
    callnative(Script_Improvbattling_ReturnValueFromProgress)
    switch (var(VAR_RESULT))
    {
        case CHECK_QUEST_IMPROVBATTLING_HAS_NOT_BEATEN_NERIENE:
            msgbox(format("Yes, and I'm hoping to be Champion."),,SPEAKER_PLAYER)
        case CHECK_QUEST_IMPROVBATTLING_HAS_BEATEN_NERIENE:
            msgbox(format("Yes, and I just beat Neriene and I'm training to be the Champion."),,SPEAKER_PLAYER)
        case CHECK_QUEST_IMPROVBATTLING_IS_CHAMPION:
            msgbox(format("Yes, and -"),,SPEAKER_PLAYER)
            msgbox(format("Oh, I know you… you’re the Champion!"),,SPEAKER_IMPROVTROUPEC)
    }
    msgbox(format("Oh wow, a real contender! And great “yes, ands” too!"),,SPEAKER_IMPROVTROUPEB)
    msgbox(format("Get ready folks, {PLAYER} is about to show us some serious skills!"),,SPEAKER_IMPROVTROUPEC)
    closemessage
}

script Improvbattling_Script_MovePlayerToStage
{
    playse(SE_APPLAUSE)
    closemessage
    moveobjecttocoords(LOCALID_PLAYER,2,2,DIR_SOUTH)
    waitmovement(LOCALID_PLAYER)
    closemessage
    waitse
}

script Improvbattling_Script_ContinueChallenge
{
    msgbox(format("And now returning to the stage, it’s our star, {PLAYER}!"),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Give it up for {PLAYER}!"),,SPEAKER_IMPROVTROUPEA)
    call(Improvbattling_Script_MovePlayerToStage)
    msgbox(format("Let's see if they can keep up the momentum this time!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    goto(Improvbattling_Script_StartSwapEvent)
}

script Improvbattling_Script_PostQuestChallenge
{
    buffermapname(STR_VAR_1,MAP_PETAROSA_BOROUGH_IMPROV)
    msgbox(format("And now for a special {STR_VAR_1} Improv legend, {PLAYER}!"),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Give it up for {PLAYER}!"),,SPEAKER_IMPROVTROUPEA)
    call(Improvbattling_Script_MovePlayerToStage)
    msgbox(format("Hopefully we can keep up this time!"),,SPEAKER_IMPROVTROUPEA,,EMOTE_SWEAT)
    closemessage
    goto(Improvbattling_Script_StartSwapEvent)
}

script Improvbattling_Script_StartSwapEvent
{
    applymovement(LOCALID_PLAYER,moves(face_up))
    waitmovement(LOCALID_PLAYER)
    msgbox(format("To start, you can't use your own Pokemon. I'll hold onto those..."),,SPEAKER_IMPROVTROUPEA)
    closemessage
    special(SavePlayerParty)
    msgbox(format("And you can use these instead."),,SPEAKER_IMPROVTROUPEA)
    closemessage
    call(Improvbattling_Script_PerformSwap0)
    cueobjectplayer(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,3,0,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC)
    buffermapname(STR_VAR_1,MAP_PETAROSA_BOROUGH_IMPROV)
    msgbox(format("Welcome to {STR_VAR_1} Improv, {PLAYER}. Let's put on a good show!"),,SPEAKER_IMPROVTROUPEC)
    closemessage
    goto(Improvbattling_Script_StartBattle1)
// start battle

	//factory_generaterentalmons
	//factory_generateopponentmons
	//factory_getopponentmontype
	//setorcopyvar(VAR_0x8005, VAR_RESULT)
	//factory_getopponentstyle
	//setorcopyvar (VAR_0x8006, VAR_RESULT)
	//call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentType)
	//call(BattleFrontier_BattleFactoryPreBattleRoom_EventScript_CommentOnOpponentStyle)
	//msgbox(BattleFrontier_BattleFactoryPreBattleRoom_Text_HoldMonsChooseFromSelection, MSGBOX_DEFAULT)
	//fadescreen(FADE_TO_BLACK)
	//factory_setswapped
	//factory_rentmons
	//waitstate
}

script Improvbattling_Script_StartBattle1
{
    trainerbattle_continue_after_lose(TRAINER_IMPROV_3,format("Well played! You've got some impressive skills."))
    specialvar(VAR_RESULT,GetBattleOutcome)
    goto_if_eq(VAR_RESULT,B_OUTCOME_LOST,Improvbattling_Script_PlayerLost)
    goto(Improvbattling_Script_AfterBattle1)
}

script Improvbattling_Script_AfterBattle1
{
    random(7)
    switch (var(VAR_RESULT))
    {
        case 0: bufferstring(STR_VAR_1,format("sick"))
        case 1: bufferstring(STR_VAR_1,format("tough"))
        case 2: bufferstring(STR_VAR_1,format("intoxicating"))
        case 3: bufferstring(STR_VAR_1,format("solid"))
        case 4: bufferstring(STR_VAR_1,format("fiery"))
        case 5: bufferstring(STR_VAR_1,format("electrifying"))
        case 6: bufferstring(STR_VAR_1,format("fierce"))
        case 7: bufferstring(STR_VAR_1,format("enchanting"))
    }

    msgbox(format("That was {STR_VAR_1}! Give it up for {PLAYER}!"),,SPEAKER_IMPROVTROUPEC)
    closemessage
    playse(SE_APPLAUSE)
    waitse
    msgbox(format("You're gonna battle ImprovtroupeB next."),,SPEAKER_IMPROVTROUPEC)
    cueobject(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC,DIR_SOUTH)
    bufferspeciesname(STR_VAR_1,SPECIES_BUNEARY)
    buffermovename(STR_VAR_2,MOVE_CELEBRATE)
    msgbox(format("Between you and me, they've got a {STR_VAR_1} that knows {STR_VAR_2}."),,SPEAKER_IMPROVTROUPEC,TAIL_WHISPER)
    closemessage
    msgbox(format("So {PLAYER}, do you want to trade one of the Pokemon you used in battle for one of mine?"),MSGBOX_YESNO,SPEAKER_IMPROVTROUPEC)
    call_if_eq(VAR_RESULT,YES,Improvbattling_Script_PerformSwap1)
    goto(Improvbattling_Script_BeforeBattle2)
}

script Improvbattling_Script_PerformSwap0
{
    special(SavePlayerParty)
    callnative(ZeroPlayerPartyMons)
    givemon(SPECIES_KLEAVOR,50,0)
    givemon(SPECIES_SCYTHER,50,0)
    givemon(SPECIES_SCIZOR,50,0)
}

script Improvbattling_Script_PerformSwap1
{
    callnative(ZeroPlayerPartyMons)
    givemon(SPECIES_MAGMORTAR,50,0)
    givemon(SPECIES_SCYTHER,50,0)
    givemon(SPECIES_SCIZOR,50,0)
    msgbox(format("Choose wisely!"),,SPEAKER_IMPROVTROUPEC)
    closemessage
}

script Improvbattling_Script_PerformSwap2
{
    callnative(ZeroPlayerPartyMons)
    givemon(SPECIES_MAGMAR,50,0)
    givemon(SPECIES_MAGMORTAR,50,0)
    givemon(SPECIES_SCIZOR,50,0)
    msgbox(format("What are you going to swap for?"),,SPEAKER_IMPROVTROUPEB)
    closemessage
}

script Improvbattling_Script_BeforeBattle2
{
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC,1,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB)
    msgbox(format("Now the real show begins. Here's Act 2!"),,SPEAKER_IMPROVTROUPEB)
    closemessage
    goto(Improvbattling_Script_StartBattle2)
}

script Improvbattling_Script_StartBattle2
{
    trainerbattle_continue_after_lose(TRAINER_IMPROV_2,format("You got me this time!"))
    specialvar(VAR_RESULT,GetBattleOutcome)
    goto_if_eq(VAR_RESULT,B_OUTCOME_LOST,Improvbattling_Script_PlayerLost)
    goto(Improvbattling_Script_AfterBattle2)
}

script Improvbattling_Script_AfterBattle2
{
    random(7)
    switch (var(VAR_RESULT))
    {
        case 0: bufferstring(STR_VAR_1,format("sick"))
        case 1: bufferstring(STR_VAR_1,format("tough"))
        case 2: bufferstring(STR_VAR_1,format("intoxicating"))
        case 3: bufferstring(STR_VAR_1,format("solid"))
        case 4: bufferstring(STR_VAR_1,format("fiery"))
        case 5: bufferstring(STR_VAR_1,format("electrifying"))
        case 6: bufferstring(STR_VAR_1,format("fierce"))
        case 7: bufferstring(STR_VAR_1,format("enchanting"))
    }

    msgbox(format("What a {STR_VAR_1} battle! Let's hear it for {PLAYER}!"),,SPEAKER_IMPROVTROUPEC)
    closemessage
    playse(SE_APPLAUSE)
    waitse
    msgbox(format("Your final battle will be against ImprovtroupeA."),,SPEAKER_IMPROVTROUPEB)
    cueobject(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB,DIR_SOUTH)
    bufferstring(STR_VAR_1,format("Grass"))
    msgbox(format("If I'm remembering correctly, the most common type on their team is {STR_VAR_1}-type."),,SPEAKER_IMPROVTROUPEB,TAIL_WHISPER)
    closemessage
    msgbox(format("So {PLAYER}, do you want to trade one of the Pokemon you used in battle for one of mine?"),MSGBOX_YESNO,SPEAKER_IMPROVTROUPEB)
    call_if_eq(VAR_RESULT,YES,Improvbattling_Script_PerformSwap2)
    goto(Improvbattling_Script_BeforeBattle3)
}

script Improvbattling_Script_BeforeBattle3
{
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB,3,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    msgbox(format("Now for the final battle of your performance!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    goto(Improvbattling_Script_StartBattle3)
}

script Improvbattling_Script_StartBattle3
{
    trainerbattle_continue_after_lose(TRAINER_IMPROV_3,format("You got the best of us!"))
    specialvar(VAR_RESULT,GetBattleOutcome)
    goto_if_eq(VAR_RESULT,B_OUTCOME_LOST,Improvbattling_Script_PlayerLost)
    goto(Improvbattling_Script_AfterBattle3)
}

script Improvbattling_Script_AfterBattle3
{
    playse(SE_APPLAUSE)
    msgbox(format("Wow! You're an improvisation natural, {PLAYER}."),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Have you thought about a career in acting at all?"),,SPEAKER_IMPROVTROUPEA,TAIL_WHISPER)
    closemessage
    waitse
    completequest(QUEST_IMPROVBATTLING)
    goto(Improvbattling_Script_PlayerLost)
}

script Improvbattling_Script_RestoreParty
{
    callnative(ZeroPlayerPartyMons)
    special(LoadPlayerParty)
}

script Improvbattling_Script_PlayerLost
{
    call(Improvbattling_Script_RestoreParty)
    cueobject(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,DIR_SOUTH)
    msgbox(format("That’s our show! Thanks for coming out and supporting us, and another round of applause for {PLAYER}! Support your local Trainers!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    playse(SE_APPLAUSE)
    fadescreen(FADE_TO_BLACK)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEB,3,1)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEC,1,1)
    setobjectxy(LOCALID_PLAYER,4,3)
    TeleportCamera(4,3)
    turnobject(LOCALID_PLAYER,DIR_NORTH)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,4,2)
    waitse
    fadescreen(FADE_FROM_BLACK)
    msgbox(format("You were really great!"),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Anytime you want to join us again just come up on stage."),,SPEAKER_IMPROVTROUPEA)
    msgbox(format("Unless one of us makes it big in the acting world, we'll be here!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    moveobjecttocoords(LOCALID_PLAYER,4,5,DIR_NORTH)
    applymovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,moves(walk_faster_down * 2))
    waitmovement(LOCALID_PLAYER)
    playse(SE_PIN)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    waitse
    msgbox(format("You forgot your Pokémon!"),,SPEAKER_IMPROVTROUPEA)
    closemessage
    cueobjecttalking(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEA)
    release
    end
}

