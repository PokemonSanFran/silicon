    msgbox(format("We're still getting ourselves ready to perform with somebody of your caliber!"),,SPEAKER_IMPROVTROUPEX)
    msgbox(format("I have heard that there were something similar cooking at {STR_VAR_1}'s old Gym..."),,SPEAKER_IMPROVTROUPEX)
