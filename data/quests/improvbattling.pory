    closemessage
}

script Improvbattling_Script_PerformSwap2_PostRecruit
{
    callnative(ZeroPlayerPartyMons)
    givemon(SPECIES_MAGMAR,50,0)
    givemon(SPECIES_MAGMORTAR,50,0)
    givemon(SPECIES_SCIZOR,50,0)
    msgbox(format("What are you interested in?"),,SPEAKER_IMPROVTROUPEY)
    closemessage
}

script Improvbattling_Script_BeforeBattle2_PostRecruit
{
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEZ,1,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEZ)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY)
    msgbox(format("I hope I can fill the shoes of ImprovtroupeB"),,SPEAKER_IMPROVTROUPEY)
    closemessage
    goto(Improvbattling_Script_StartBattle2_PostRecruit)
}

script Improvbattling_Script_StartBattle2_PostRecruit
{
    trainerbattle_continue_after_lose(TRAINER_IMPROV_2,format("Did we live up to expectations?"))
    specialvar(VAR_RESULT,GetBattleOutcome)
    goto_if_eq(VAR_RESULT,B_OUTCOME_LOST,Improvbattling_Script_PlayerLost_PostRecruit)
    goto(Improvbattling_Script_AfterBattle2_PostRecruit)
}

script Improvbattling_Script_AfterBattle2_PostRecruit
{
    msgbox(format("Thanks again for coming out, {PLAYER}!"),,SPEAKER_IMPROVTROUPEZ)
    closemessage
    playse(SE_APPLAUSE)
    waitse
    msgbox(format("Finally, you'll battle ImprovtroupeX."),,SPEAKER_IMPROVTROUPEY)
    cueobject(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY,DIR_SOUTH)
    bufferstring(STR_VAR_1,format("Grass"))
    msgbox(format("Heads up, {STR_VAR_1} is the most common type on their team."),,SPEAKER_IMPROVTROUPEY,TAIL_WHISPER)
    closemessage
    msgbox(format("{PLAYER}, do you want to trade one of the Pokemon you used in battle for one of mine?"),MSGBOX_YESNO,SPEAKER_IMPROVTROUPEY)
    call_if_eq(VAR_RESULT,YES,Improvbattling_Script_PerformSwap2_PostRecruit)
    goto(Improvbattling_Script_BeforeBattle3_PostRecruit)
}

script Improvbattling_Script_BeforeBattle3_PostRecruit
{
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY,3,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX)
    msgbox(format("The legendary {PLAYER}! We've heard so much."),,SPEAKER_IMPROVTROUPEX)
    closemessage
    goto(Improvbattling_Script_StartBattle3_PostRecruit)
}

script Improvbattling_Script_StartBattle3_PostRecruit
{
    trainerbattle_continue_after_lose(TRAINER_IMPROV_3,format("We're not ready for somebody of your caliber!"))
    specialvar(VAR_RESULT,GetBattleOutcome)
    goto_if_eq(VAR_RESULT,B_OUTCOME_LOST,Improvbattling_Script_PlayerLost_PostRecruit)
    goto(Improvbattling_Script_AfterBattle3_PostRecruit)
}

script Improvbattling_Script_AfterBattle3_PostRecruit
{
    playse(SE_APPLAUSE)
    msgbox(format("The legend: {PLAYER}!"),,SPEAKER_IMPROVTROUPEX)
    closemessage
    waitse
    goto(Improvbattling_Script_PlayerLost_PostRecruit)
}

script Improvbattling_Script_PlayerLost_PostRecruit
{
    call(Improvbattling_Script_RestoreParty)
    cueobject(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX,DIR_SOUTH)
    msgbox(format("Remember everybody, support your local Trainers!"),,SPEAKER_IMPROVTROUPEX)
    closemessage
    playse(SE_APPLAUSE)
    fadescreen(FADE_TO_BLACK)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEY,3,1)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEZ,1,1)
    setobjectxy(LOCALID_PLAYER,4,3)
    TeleportCamera(4,3)
    turnobject(LOCALID_PLAYER,DIR_NORTH)
    setobjectxy(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX,4,2)
    waitse
    fadescreen(FADE_FROM_BLACK)
    msgbox(format("You're always welcome, here {PLAYER}!"),,SPEAKER_IMPROVTROUPEX)
    closemessage
    cueobjecttalking(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX)
    msgbox(format("Here are your Pokemon, {PLAYER}."),,SPEAKER_IMPROVTROUPEX)
    closemessage
    moveobjecttocoords(LOCALID_PLAYER,4,5,DIR_NORTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX)
    moveobjecttocoords(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX,2,1,DIR_SOUTH)
    waitmovement(LOCALID_PETAROSA_THEATER_IMPROVTROUPEX)
    release
    end
}

