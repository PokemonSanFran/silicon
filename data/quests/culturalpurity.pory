}

script CulturalPurity_Dialogue_ReadyForA_BackroomguardB
{
    setvar(VAR_CULTURAL_PURITY,CULTURAL_PURITY_PAYWALL_B)
    call(CulturalPurity_Dialogue_PlayerCaw)
    bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
    msgbox(format("Welcome to Level B, great {STR_VAR_1}."),,SPEAKER_BACKROOMGUARDB)
    msgbox(format("That tile and your donation will get you into Level B."),,SPEAKER_BACKROOMGUARDB)
    msgbox(format("I paid the initiation donation!"),,SPEAKER_PLAYER,,EMOTE_SHOCK)
    msgbox(format("As do we all. The promotion donation is quite different."),,SPEAKER_BACKROOMGUARDB)
    goto(CulturalPurity_Dialogue_AskDonation_BackroomguardB)
}

script CulturalPurity_Dialogue_AskDonation_BackroomguardB
{
    checkmoney(COST_QUEST_CULTURAL_PURITY_B)
    showmoneybox(0,0)
    goto_if_ne(VAR_RESULT,TRUE,CulturalPurity_Dialogue_DenyDonation_BackroomguardB)
    callnative(Quest_CulturalPurity_BufferCostLevelB)
    msgbox(format("To enter Level B, you’ll need the promotion donation of ¥{STR_VAR_2}."),MSGBOX_YESNO,SPEAKER_BACKROOMGUARDB)
    goto_if_eq(VAR_RESULT,NO,CulturalPurity_Dialogue_DenyDonation_BackroomguardB)
    removemoney(COST_QUEST_CULTURAL_PURITY_B)
    setvar(VAR_CULTURAL_PURITY,CULTURAL_PURITY_OPEN_B)
    waitbuttonpress
    playse(SE_SHOP)
    updatemoneybox
    waitse
    hidemoneybox
    closemessage
    fadescreen(FADE_TO_BLACK)
    playse(SE_BRIDGE_WALK)
    waitse
    call(CulturalPurity_Script_RevealBackroomB)
    playse(SE_BRIDGE_WALK)
    waitse
    fadescreen(FADE_FROM_BLACK)
    call(CulturalPurity_Dialogue_WelcomeToB)
    call(CulturalPurity_Dialogue_ShinzoDiscussLeavingB)
}

script CulturalPurity_Dialogue_ShinzoDiscussLeavingB
{
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_SHINZO,LOCALID_COOKIE_SHINZO,4,1,MOVEMENT_TYPE_FACE_DOWN)
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,4,2,DIR_SOUTH)
    waitse
    waitmovement(LOCALID_COOKIE_SHINZO)
    moveobjecttocoords(LOCALID_PLAYER,7,3,DIR_WEST)
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,6,3,DIR_EAST)
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("{PLAYER}! I got better at the riddles, and finding this place was easy."),,SPEAKER_SHINZO)
    msgbox(format("That was so fast!"),,SPEAKER_PLAYER,TAIL_THOUGHT,EMOTE_SHOCK)
    msgbox(format("Race me to Level C, yes?"),,SPEAKER_SHINZO)
    closemessage
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,4,7,DIR_SOUTH)
    delay(16)
    fadescreen(FADE_TO_BLACK)
    playse(SE_EXIT)
    removeobject(LOCALID_COOKIE_SHINZO)
    fadescreen(FADE_FROM_BLACK)
    waitse
    release
    end
}

