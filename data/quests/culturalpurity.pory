script CulturalPurity_Script_InteractBackroomtrainerB1
{
    lock
    faceplayer
    call(CulturalPurity_Script_TryRejectPlayerB)
    if (defeated(TRAINER_BACKROOMTRAINERB1) == FALSE)
    {
        msgbox(format("Hold items just introduce a layer between you and your Pokemon."),,SPEAKER_BACKROOMTRAINERB1)
        closemessage
        trainerbattle_no_intro(TRAINER_BACKROOMTRAINERB1,format("I guess my Pokemon and I aren’t close enough…"))
        addvar(VAR_CULTURAL_PURITY,1)
        release
        end
    }
    buffermovename(STR_VAR_1,MOVE_OUTRAGE)
    bufferitemname(STR_VAR_2,ITEM_PERSIM_BERRY)
    msgbox(format("I know what the Masters say, but battling without items is hard. I used to love using {STR_VAR_1} while holding a {STR_VAR_2}. It meant no drawbacks after my Pokemon got fatigued!"),,SPEAKER_BACKROOMTRAINERB1)
    closemessage
    release
    end
}

script CulturalPurity_Script_InteractBackroomtrainerB2
{
    lock
    faceplayer
    call(CulturalPurity_Script_TryRejectPlayerB)
    if (defeated(TRAINER_BACKROOMTRAINERB2) == FALSE)
    {
        msgbox(format("You know, maybe these guys are onto something. Sometimes it's stronger not to hold an item!"),,SPEAKER_BACKROOMTRAINERB2)
        closemessage
        trainerbattle_no_intro(TRAINER_BACKROOMTRAINERB2,format("You’ve begun to master the old ways too…"))
        addvar(VAR_CULTURAL_PURITY,1)
        release
        end
    }
    bufferabilityname(STR_VAR_1,ABILITY_UNBURDEN)
    bufferabilityname(STR_VAR_2,ABILITY_KLUTZ)
    msgbox(format("The Ability {STR_VAR_1} doubles the Pokémon's Speed stat when the Pokémon's held item is used or lost. Pokemon with the Ability {STR_VAR_2} can’t use items at all!"),,SPEAKER_BACKROOMTRAINERB2)
    closemessage
    release
    end
}

script CulturalPurity_Script_InteractBackroomtrainerB3
{
    lock
    faceplayer
    call(CulturalPurity_Script_TryRejectPlayerB)
    callnative(Script_Quest_CulturalPurity_HasDefeatedAllPeonsLevelB)
    if (var(VAR_RESULT) == FALSE)
    {
        bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
        msgbox(format("It’s good to see you in Level B of the Seafoam {STR_VAR_1} Society. Once you’ve defeated the others, come talk to me."),,SPEAKER_BACKROOMTRAINERB3)
        closemessage
        release
        end
    }
    if (defeated(TRAINER_BACKROOMTRAINERB3) == FALSE)
    {
        msgbox(format("Do you think you can graduate to Level C?"),,SPEAKER_BACKROOMTRAINERB3)
        closemessage
        trainerbattle_no_intro(TRAINER_BACKROOMTRAINERB3,format("Kaw! Great progress!"))
        addvar(VAR_CULTURAL_PURITY,1)
        goto(CulturalPurity_Dialogue_LevelBCleared)
    }
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_BACKROOMTRAINERB3,TAIL_SHOUT)
    waitmoncry
    call(CulturalPurity_Dialogue_ExplainLevelC)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_ExplainLevelC
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_3)
    msgbox(format("To enter Level C, bring the {STR_VAR_1} to the southwestern passage between two kingdoms."),,SPEAKER_BACKROOMTRAINERB3)
    msgbox(format("Level C requires that your party must only have two types, cannot be holding items, and all of your Pokemon must know at least two moves that match their types."),,SPEAKER_BACKROOMTRAINERB3)
}

script CulturalPurity_Dialogue_LevelBCleared
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_2)
    msgbox(format("Your {STR_VAR_1}, please."),,SPEAKER_BACKROOMTRAINERB3)
    closemessage
    removeitem(ITEM_QUEST_CULTURALPURITY_2,1)
    cueobjecttalking(LOCALID_PLAYER)
    cueobjecttalking(LOCALID_BACKROOMTRAINERB3)
    giveitem(ITEM_QUEST_CULTURALPURITY_3,1)
    call(CulturalPurity_Dialogue_ExplainLevelC)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_BackroomguardC_Caw
{
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_BACKROOMGUARDC,TAIL_SHOUT)
    waitmoncry
}

script CulturalPurity_Script_Interact_BackroomguardC
{
    lock
    faceplayer
    goto_if_ge(VAR_CULTURAL_PURITY,CULTURAL_PURITY_OPEN_C,CulturalPurity_Dialogue_WelcomeToC_Standalone)
    goto_if_ge(VAR_CULTURAL_PURITY,CULTURAL_PURITY_PAYWALL_C,CulturalPurity_Dialogue_AskDonation_BackroomguardC)
    call(CulturalPurity_Dialogue_BackroomguardC_Caw)
    closemessage
    goto_if_eq(VAR_CULTURAL_PURITY,CULTURAL_PURITY_READY_FOR_C,CulturalPurity_Dialogue_Begin_BackroomguardC)
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_3)
    msgbox(format("I’m looking to play a game of Mahjong… but I’m missing a {STR_VAR_1}."),,SPEAKER_BACKROOMGUARDC)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_Begin_BackroomguardC
{
    callnative(Script_Quest_CulturalPurity_IsPlayerReadyForLevelC)
    goto_if_eq(VAR_RESULT,TRUE,CulturalPurity_Dialogue_ReadyForC_BackroomguardC)
    call(CulturalPurity_Dialogue_PlayerCaw)
    msgbox(format("To continue your journey, your party must only have two types, cannot be holding items, and all of your Pokemon must know at least two moves that match their types."),,SPEAKER_BACKROOMGUARDC)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_ReadyForC_BackroomguardC
{
    setvar(VAR_CULTURAL_PURITY,CULTURAL_PURITY_PAYWALL_C)
    call(CulturalPurity_Dialogue_PlayerCaw)
    bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
    msgbox(format("Welcome to Level C, mighty {STR_VAR_1}."),,SPEAKER_BACKROOMGUARDC)
    msgbox(format("That tile and your donation will get you into Level C."),,SPEAKER_BACKROOMGUARDC)
    msgbox(format("Is there a donation at every level?"),,SPEAKER_PLAYER,,EMOTE_ANGRY)
    msgbox(format("The next and final level is true ascension. Is this not what everyone desires, no matter the cost?"),,SPEAKER_BACKROOMGUARDC)
    goto(CulturalPurity_Dialogue_AskDonation_BackroomguardC)
}

script CulturalPurity_Dialogue_AskDonation_BackroomguardC
{
    checkmoney(COST_QUEST_CULTURAL_PURITY_C)
    showmoneybox(0,0)
    goto_if_ne(VAR_RESULT,TRUE,CulturalPurity_Dialogue_DenyDonation_BackroomguardC)
    callnative(Quest_CulturalPurity_BufferCostLevelC)
    msgbox(format("To enter Level C, you’ll need the devotion donation of ¥{STR_VAR_2}."),MSGBOX_YESNO,SPEAKER_BACKROOMGUARDC)
    goto_if_eq(VAR_RESULT,NO,CulturalPurity_Dialogue_DenyDonation_BackroomguardC)
    removemoney(COST_QUEST_CULTURAL_PURITY_C)
    setvar(VAR_CULTURAL_PURITY,CULTURAL_PURITY_OPEN_C)
    waitbuttonpress
    playse(SE_SHOP)
    updatemoneybox
    waitse
    hidemoneybox
    closemessage
    fadescreen(FADE_TO_BLACK)
    playse(SE_BRIDGE_WALK)
    waitse
    call(CulturalPurity_Script_RevealBackroomC)
    playse(SE_BRIDGE_WALK)
    waitse
    fadescreen(FADE_FROM_BLACK)
    call(CulturalPurity_Dialogue_WelcomeToC)
}


script CulturalPurity_Script_RevealBackroomC
{
    setmetatile(4,7,0x0A7,FALSE)
    special(DrawWholeMapView)
}

script CulturalPurity_Dialogue_WelcomeToC
{
    playmoncry(SPECIES_FEAROW,CRY_MODE_NORMAL)
    msgbox(format("Kaw! Welcome to Level C."),,SPEAKER_BACKROOMGUARDC)
    waitmoncry
    closemessage
}

script CulturalPurity_Dialogue_WelcomeToC_Standalone
{
    call(CulturalPurity_Dialogue_WelcomeToC)
    release
    end
}

script CulturalPurity_Dialogue_DenyDonation_BackroomguardC
{
    callnative(Quest_CulturalPurity_BufferCostLevelC)
    msgbox(format("Kaw! Return when you are ready to make your ¥{STR_VAR_2} donation."),,SPEAKER_BACKROOMGUARDC)
    closemessage
    hidemoneybox
    release
    end
}

script CulturalPurity_Script_TryRejectPlayerC
{
    if (var(VAR_CULTURAL_PURITY) >= CULTURAL_PURITY_READY_FOR_C)
    {
        return
    }
    callnative(Script_Quest_CulturalPurity_IsPlayerReadyForLevelC)
    goto_if_eq(VAR_RESULT,FALSE,CulturalPurity_Dialogue_RejectLevelC)
}

script CulturalPurity_Dialogue_RejectLevelC
{
    fadescreen(FADE_TO_BLACK)
    msgbox(format("The lights turned off!"))
    msgbox(format("Your party is not pure."),,SPEAKER_SOCIETY)
    msgbox(format("You may only return when you have met the purity for our level."),,SPEAKER_SOCIETY)
    msgbox(format("All the Pokémon in your party may only share one or two types."),,SPEAKER_SOCIETY)
    msgbox(format("All the Pokémon in your party must not be holding items."),,SPEAKER_SOCIETY)
    msgbox(format("All the Pokémon in your party must know at least two moves that match their types."),,SPEAKER_SOCIETY)
    msgbox(format("Begone."),,SPEAKER_SOCIETY)
    closemessage
    warpsilent(MAP_HODOU_CITY_HERBAL,WARP_ID_COOKIE_TO_BACKROOM_B)
    waitstate
    release
    end
}

script CulturalPurity_Script_Hide_BackroomguardC
{
    setobjectflagfromlocalid(LOCALID_ALLEY_1_BACKROOMGUARDC)
}

script CulturalPurity_Dialogue_StartBackroomC
{
    lock
    call(CulturalPurity_Script_ResumeBattleC)
    applymovement(LOCALID_PLAYER,moves(walk_up))
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_SHINZO,LOCALID_COOKIE_SHINZO,5,5,MOVEMENT_TYPE_FACE_UP)
    waitse
    applymovement(LOCALID_COOKIE_SHINZO,moves(walk_up))
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("Found the alleyway just in time!"),,SPEAKER_SHINZO)
    closemessage
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_left,delay_16,face_right,delay_16,face_up,delay_16))
    waitmovement(LOCALID_COOKIE_SHINZO)
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,5,2,DIR_NORTH)
    moveobjecttocoords(LOCALID_PLAYER,6,2,DIR_NORTH)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("…is it just you two?"),,SPEAKER_SHINZO)
    msgbox(format("It takes the most training to reach Level C!"),,SPEAKER_BACKROOMTRAINERC2)
    callnative(Quest_CulturalPurity_BufferCostRacks)
    msgbox(format("And not just anyone can cough up {STR_VAR_1} racks."),,SPEAKER_BACKROOMTRAINERC1,TAIL_WHISPER)
    msgbox(format("Is there any rule against Double Battles?"),,SPEAKER_SHINZO)
    msgbox(format("I’ve never heard of a restriction like that…"),,SPEAKER_BACKROOMTRAINERC2)
    msgbox(format("Excellent."),,SPEAKER_SHINZO)
    closemessage
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_player))
    applymovement(LOCALID_PLAYER,moves(face_left))
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("I’m so close to the top! I imagine the leader is the purest of them all, and once I train with them, I’ll be able to distill Sinnoh’s culture back to its rawest, Hisuian roots."),,SPEAKER_SHINZO)
    msgbox(format("Let’s hurry up with Level C!"),,SPEAKER_SHINZO)
    closemessage
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_up))
    applymovement(LOCALID_PLAYER,moves(face_up))
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    goto(CulturalPurity_Script_StartBattleC)
}

script CulturalPurity_Script_ResumeBattleC
{
    checktrainerdiscovered(TRAINER_BACKROOMTRAINERC1)
    if (var(VAR_RESULT) == FALSE)
    {
        return
    }

    fadescreen(FADE_TO_BLACK)
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_SHINZO,LOCALID_COOKIE_SHINZO,5,2,MOVEMENT_TYPE_FACE_UP)
    setobjectxy(LOCALID_PLAYER,6,2)
    TeleportCamera(6,2)
    waitse
    fadescreen(FADE_FROM_BLACK)
    goto(CulturalPurity_Script_StartBattleC)
}

script CulturalPurity_Script_StartBattleC
{
    multi_2_vs_2(TRAINER_BACKROOMTRAINERC1,format("I blew my savings for this?"),TRAINER_BACKROOMTRAINERC2,format("I’ve never seen Trainers progress this quickly…"),PARTNER_SHINZO)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    addvar(VAR_CULTURAL_PURITY,CULTURAL_PURITY_DEFEATED_C)
    goto(CulturalPurity_Dialogue_LevelCCleared)
}

script CulturalPurity_Dialogue_LevelCCleared
{
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_BACKROOMTRAINERC2,TAIL_SHOUT)
    waitmoncry

    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_3)
    msgbox(format("Your {STR_VAR_1}, please."),,SPEAKER_BACKROOMTRAINERC2)
    closemessage
    removeitem(ITEM_QUEST_CULTURALPURITY_3,1)
    cueobjecttalking(LOCALID_PLAYER)
    cueobjecttalking(LOCALID_BACKROOMTRAINERC2)
    giveitem(ITEM_QUEST_CULTURALPURITY_4,1)
    call(CulturalPurity_Dialogue_ExplainLevelD)
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_player))
    applymovement(LOCALID_PLAYER,moves(face_left))
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("We’re stronger now… I think?"),,SPEAKER_SHINZO)
    buffermapname(STR_VAR_1,MAP_HODOU_CITY)
    msgbox(format("There’s a house in {STR_VAR_1} with somebody standing out front. I thought they were unwell, but now…"),,SPEAKER_SHINZO)
    closemessage
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,5,5,DIR_SOUTH)
    delay(8)
    fadescreen(FADE_TO_BLACK)
    playse(SE_EXIT)
    removeobject(LOCALID_COOKIE_SHINZO)
    fadescreen(FADE_FROM_BLACK)
    waitse
    release
    end
}

script CulturalPurity_Dialogue_ExplainLevelD
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_4)
    msgbox(format("To enter Level D, bring the {STR_VAR_1} to the northeastern bird’s nest."),,SPEAKER_BACKROOMTRAINERC2)
    msgbox(format("Do not worry about earthly tethers or restrictions. You are pure enough."),,SPEAKER_BACKROOMTRAINERC2)
    closemessage
}

script CulturalPurity_Script_InteractBackroomtrainerC1
{
    lock
    msgbox(format("I don’t know if I can afford to keep up with this training."),,SPEAKER_BACKROOMTRAINERC1)
    closemessage
    release
    end
}

script CulturalPurity_Script_InteractBackroomtrainerC2
{
    lock
    faceplayer
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_BACKROOMTRAINERC2,TAIL_SHOUT)
    call(CulturalPurity_Dialogue_ExplainLevelD)
    waitmoncry
    release
    end
}

script CulturalPurity_Dialogue_Culthouse_Caw
{
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_CULTHOUSEGUARD,TAIL_SHOUT)
    waitmoncry
}

script CulturalPurity_Script_Interact_Culthouseguard
{
    lock
    faceplayer
    call(CulturalPurity_Script_ResumeBattleD)
    call(CulturalPurity_Dialogue_Culthouse_Caw)
    goto_if_lt(VAR_CULTURAL_PURITY,CULTURAL_PURITY_READY_FOR_D,CulturalPurity_Dialogue_BlockPlayerItem)
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw."),,SPEAKER_PLAYER)
    waitmoncry
    closemessage
    moveobjecttocoords(LOCALID_PLAYER,12,16,DIR_NORTH)
    clearobjectflagfromlocalid(LOCALID_PLAYER)
    applymovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD,moves(face_down))
    waitmovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    addobject(LOCALID_HODOU_SHINZO)
    setobjectmovementtype(LOCALID_HODOU_SHINZO,MOVEMENT_TYPE_FACE_UP)
    setobjectxy(LOCALID_HODOU_SHINZO,12,21)
    moveobjecttocoords(LOCALID_HODOU_SHINZO,11,16,DIR_NORTH)
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    playmoncry(SPECIES_QUEST_CULTURAL_PURITY_MASCOT,CRY_MODE_NORMAL)
    msgbox(format("Kaw!"),,SPEAKER_SHINZO,TAIL_SHOUT)
    waitmoncry
    bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
    msgbox(format("Your training has awarded you that tile, and brought you to the apex of understanding - the top of the Seafoam {STR_VAR_1} Society."),,SPEAKER_CULTHOUSEGUARD)
    msgbox(format("Now, to train with the master, you must release your earthly tether."),,SPEAKER_CULTHOUSEGUARD)
    msgbox(format("You must release every Pokémon in your PC Boxes. You may only own the Pokémon in your party."),,SPEAKER_CULTHOUSEGUARD)
    callnative(Script_Quest_CulturalPurity_IsPlayerReadyForLevelD)
    call_if_eq(VAR_RESULT,TRUE,CulturalPurity_Dialogue_PlayerHasNoBoxMons)
    goto(CulturalPurity_Dialogue_RejectCult)
}

script CulturalPurity_Dialogue_PlayerHasNoBoxMons
{
    msgbox(format("You, {PLAYER}, have clearly prepared for this task."),,SPEAKER_CULTHOUSEGUARD)
    msgbox(format("But you Shinzo - I can see you are not quite ready."),,SPEAKER_CULTHOUSEGUARD)
    goto(CulturalPurity_Dialogue_RejectCult)
}

script CulturalPurity_Dialogue_BlockPlayerItem
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_4)
    msgbox(format("Only those with the {STR_VAR_1} can enter."),,SPEAKER_CULTHOUSEGUARD)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_RejectCult
{
    msgbox(format("Release my Pokémon? But those are my friends, I trained them -"),,SPEAKER_SHINZO)
    msgbox(format("All right, that’s enough."),,SPEAKER_PLAYER)
    closemessage
    playse(SE_PIN)
    applymovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD,moves(emote_exclamation_mark))
    applymovement(LOCALID_HODOU_SHINZO,moves(emote_exclamation_mark))
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    waitse
    msgbox(format("We’ve followed every word so far, paid every donation, and even squawked like a bird!"),,SPEAKER_PLAYER)
    msgbox(format("This is where we draw the line."),,SPEAKER_PLAYER)
    closemessage
    applymovement(LOCALID_HODOU_SHINZO,moves(face_right))
    applymovement(LOCALID_PLAYER,moves(face_left))
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("These people are insane. I don’t know what good old days they’re trying to recreate, but you’re plenty strong without… whatever this is. You’re already a Gym Leader!"),,SPEAKER_PLAYER)
    msgbox(format("But true strength comes from…"),,SPEAKER_SHINZO)
    msgbox(format("Not paying weirdos."),,SPEAKER_PLAYER)
    msgbox(format("We will not stand by while you mock us!"),,SPEAKER_CULTHOUSEGUARD)
    closemessage
    applymovement(LOCALID_HODOU_SHINZO,moves(face_up))
    applymovement(LOCALID_PLAYER,moves(face_up))
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    opendoor(12,14)
    waitdooranim
    moveobjecttocoords(LOCALID_HODOU_CITY_CULTHOUSEGUARD,12,14,DIR_NORTH)
    waitmovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    playse(SE_EXIT)
    removeobject(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    waitse
    delay(16)
    delay(16)
    playse(SE_EXIT)
    setobjectxyperm(LOCALID_HODOU_CITY_CULTHOUSEGUARD,12,14)
    clearobjectflagfromlocalid(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    addobject(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    moveobjecttocoords(LOCALID_HODOU_CITY_CULTHOUSEGUARD,11,15,DIR_SOUTH)
    waitse
    playse(SE_EXIT)
    spawnobject(OBJ_EVENT_GFX_LASS,LOCALID_HODOU_CULTLEADER,12,14,MOVEMENT_TYPE_FACE_DOWN)
    moveobjecttocoords(LOCALID_HODOU_CULTLEADER,12,15,DIR_SOUTH)
    waitmovement(LOCALID_HODOU_CULTLEADER)
    waitse
    closedoor(12,14)
    msgbox(format("{PLAYER}… I’ve heard a lot about you rising through the ranks. And now you turn your back on us?"),,SPEAKER_CULTLEADER)
    msgbox(format("And you, young Shinzo - aren’t you looking to be the strongest Gym Leader in Resido? In the world?"),,SPEAKER_CULTLEADER)
    msgbox(format("Please, give it a rest! Telling people to follow your weird rules and then taking their money to be part of your secret club doesn’t make them stronger. If anything, it's the opposite."),,SPEAKER_PLAYER,,EMOTE_ANGRY)
    msgbox(format("Fine. "),,SPEAKER_CULTLEADER)
    closemessage
    waitdooranim
    applymovement(LOCALID_HODOU_CULTLEADER,moves(face_up,delay_16,delay_16,face_down))
    waitmovement(LOCALID_HODOU_CULTLEADER)
    goto(CulturalPurity_Script_StartBattleD)
}

script CulturalPurity_Script_ResumeBattleD
{
    checktrainerdiscovered(TRAINER_CULTHOUSEGUARD)
    if (var(VAR_RESULT) == FALSE)
    {
        return
    }

    fadescreenswapbuffers(FADE_TO_BLACK)
    moveobjecttocoords(LOCALID_PLAYER,12,16,DIR_NORTH)
    waitmovement(LOCALID_PLAYER)

    moveobjecttocoords(LOCALID_HODOU_CITY_CULTHOUSEGUARD,11,15,DIR_SOUTH)
    spawnobject(OBJ_EVENT_GFX_LASS,LOCALID_HODOU_CULTLEADER,12,15,MOVEMENT_TYPE_FACE_DOWN)
    waitmovement(LOCALID_HODOU_CITY_CULTHOUSEGUARD)

    clearobjectflagfromlocalid(LOCALID_HODOU_SHINZO)
    setobjectmovementtype(LOCALID_HODOU_SHINZO,MOVEMENT_TYPE_FACE_UP)
    setobjectxyperm(LOCALID_HODOU_SHINZO,11,16)
    addobject(LOCALID_HODOU_SHINZO)
    setobjectxy(LOCALID_HODOU_SHINZO,11,16)

    fadescreenswapbuffers(FADE_FROM_BLACK)
    goto(CulturalPurity_Script_StartBattleD)
}

script CulturalPurity_Script_StartBattleD
{
    bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
    msgbox(format("I’ll demonstrate the full might of the Seafoam {STR_VAR_1} Society!"),,SPEAKER_CULTLEADER,TAIL_SHOUT)
    closemessage
    multi_2_vs_2(TRAINER_CULTHOUSEGUARD,format("..."),TRAINER_CULTLEADER,format("But my… focus is unmatched, my team so pure."),PARTNER_SHINZO)
    call(Silicon_Script_WhiteoutIfPlayerLostMulti)
    goto(CulturalPurity_Dialogue_PostBattle)
}

script CulturalPurity_Dialogue_PostBattle
{
    questmenu(QUEST_MENU_SET_REWARD,QUEST_CULTURALPURITY)
    msgbox(format("… How?"),,SPEAKER_CULTLEADER)
    applymovement(LOCALID_HODOU_SHINZO,moves(face_right))
    applymovement(LOCALID_PLAYER,moves(face_left))
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("I don’t think paying thousands of dollars and restricting your Pokémon is going to make you a better Trainer, Shinzo. Battling under these restrictions… it’s just a handicap."),,SPEAKER_PLAYER)
    msgbox(format("I’m starting to see that. I was starting to -"),,SPEAKER_SHINZO)
    closemessage
    playse(SE_PIN)
    applymovement(LOCALID_HODOU_SHINZO,moves(emote_exclamation_mark))
    waitse
    waitmovement(LOCALID_HODOU_SHINZO)
    msgbox(format("Wait, what do you mean by thousands of dollars?"),,SPEAKER_SHINZO)
    msgbox(format("Every time we went to a new level, we had to pay some insane donation!"),,SPEAKER_PLAYER,TAIL_SHOUT,EMOTE_ANGRY)
    msgbox(format("They didn’t ask me for any money. Is it because I’m a Gym Leader?"),,SPEAKER_SHINZO)
    playse(SE_PIN)
    applymovement(LOCALID_PLAYER,moves(emote_exclamation_mark))
    waitse
    waitmovement(LOCALID_PLAYER)
    applymovement(LOCALID_HODOU_SHINZO,moves(face_up))
    applymovement(LOCALID_PLAYER,moves(face_up))
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    bufferspeciesname(STR_VAR_1,SPECIES_QUEST_CULTURAL_PURITY_MASCOT)
    msgbox(format("…Seafoam {STR_VAR_1} Society Smoke Bomb!"),,SPEAKER_CULTLEADER,TAIL_SHOUT)
    closemessage
    cueobjecttalking(LOCALID_HODOU_CULTLEADER)
    waitmovement(LOCALID_HODOU_CULTLEADER)
    playse(SE_BALL_THROW)
    waitse
    playse(SE_M_HAZE)
    fadescreenswapbuffers(FADE_TO_WHITE)
    playse(SE_PIN)
    applymovement(LOCALID_HODOU_SHINZO,moves(emote_exclamation_mark))
    applymovement(LOCALID_PLAYER,moves(emote_exclamation_mark))
    waitse
    waitmovement(LOCALID_HODOU_SHINZO)
    waitmovement(LOCALID_PLAYER)
    removeobject(LOCALID_HODOU_CITY_CULTHOUSEGUARD)
    removeobject(LOCALID_HODOU_CULTLEADER)
    fadescreenswapbuffers(FADE_FROM_WHITE)
    msgbox(format("How did they?..."),,SPEAKER_SHINZO)
    msgbox(format("Is there anybody in the house?"),,SPEAKER_PLAYER)
    closemessage
    moveobjecttocoords(LOCALID_PLAYER,12,15,DIR_NORTH)
    waitmovement(LOCALID_PLAYER)
    warpdoor(MAP_HODOU_CITY_RACISTHOUSE,WARP_ID_CULTHOUSE_TO_HODOU_RIGHT,0,0)
    waitstate
}

script CulturalPurity_Script_TryCultCutscene
{
    lock
    addvar(VAR_TEMP_0,1)
    goto_if_quest_reward(QUEST_CULTURALPURITY,CulturalPurity_Dialogue_InsideCultHouse)
    release
    closemessage
    end
}

script CulturalPurity_Dialogue_InsideCultHouse
{
    removeitem(ITEM_QUEST_CULTURALPURITY_4,1)
    spawnobject(OBJ_EVENT_GFX_SHINZO,LOCALID_COOKIE_SHINZO,5,7,MOVEMENT_TYPE_FACE_UP)
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,5,6,DIR_NORTH)
    moveobjecttocoords(LOCALID_PLAYER,6,6,DIR_NORTH)
    waitmovement(LOCALID_COOKIE_SHINZO)
    waitmovement(LOCALID_PLAYER)
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_left,delay_16,face_up,delay_16,face_right,delay_16))
    waitmovement(LOCALID_COOKIE_SHINZO)
    msgbox(format("I thought I was so close to finding my people… people who understand my ideals."),,SPEAKER_SHINZO)
    closemessage
    applymovement(LOCALID_PLAYER,moves(face_left))
    waitmovement(LOCALID_PLAYER)
    msgbox(format("I wonder if the Leader was the only person at this level. I doubt many people were willing to release all of their Pokémon… or pay all those fees."),,SPEAKER_PLAYER)
    applymovement(LOCALID_COOKIE_SHINZO,moves(face_up,delay_16,face_right,delay_16))
    waitmovement(LOCALID_COOKIE_SHINZO)
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_4)
    msgbox(format("Player, can I have that {STR_VAR_1}? "),,SPEAKER_SHINZO)
    msgbox(format("I’m embarrassed at how naive I was. I want the tile as a reminder to never let myself be swindled like that again."),,SPEAKER_SHINZO)
    msgbox(format("It’s all yours. It’s useless to me now."),,SPEAKER_PLAYER)
    closemessage
    cueobjecttalking(LOCALID_PLAYER)
    waitmovement(LOCALID_PLAYER)
    msgbox(format("Thanks."),,SPEAKER_SHINZO)
    msgbox(format("Everything I know is Sinnoh."),,SPEAKER_SHINZO)
    msgbox(format("Most of my Pokémon are from there. How I dress, how I talk, what I eat."),,SPEAKER_SHINZO)
    msgbox(format("And even though I’m in Tora Town, I’ve always sought to get even closer to my roots - but Tora Town is just a pale imitation."),,SPEAKER_SHINZO)
    msgbox(format("Resido has strong Trainers. I’ve met them. I’ve seen it. But things here are so different! How do I incorporate their strength without compromising my authentic Sinnoh self?"),,SPEAKER_SHINZO)
    msgbox(format("I have some thinking to do. I’ll talk to you later."),,SPEAKER_SHINZO)
    closemessage
    moveobjecttocoords(LOCALID_COOKIE_SHINZO,5,7,DIR_SOUTH)
    waitmovement(LOCALID_COOKIE_SHINZO)
    playse(SE_EXIT)
    removeobject(LOCALID_COOKIE_SHINZO)
    waitse
    completequest(QUEST_CULTURALPURITY)
    release
    end
}
