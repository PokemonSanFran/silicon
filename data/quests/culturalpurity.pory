{
    callnative(Script_Quest_CulturalPurity_IsPlayerReadyForLevelB)
    goto_if_eq(VAR_RESULT,TRUE,CulturalPurity_Dialogue_ReadyForA_BackroomguardB)
    call(CulturalPurity_Dialogue_PlayerCaw)
    msgbox(format("To continue your journey, your party must only have two types and cannot be holding items."),,SPEAKER_BACKROOMGUARDB)
