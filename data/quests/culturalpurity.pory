script CulturalPurity_Dialogue_StartQuest
{
    lock
    faceplayer
    msgbox(format("Player."),,SPEAKER_SHINZO)
    checkitemspace(ITEM_QUEST_CULTURALPURITY_1,1)
    goto_if_eq(VAR_RESULT,TRUE,CulturalPurity_Dialogue_IntroduceCult)
    msgbox(format("There seems to be a lot in your bag. Come back when you’ve got more space for something vital!"),,SPEAKER_SHINZO)
    closemessage
    release
    end
}

script CulturalPurity_Dialogue_IntroduceCult
{
}
