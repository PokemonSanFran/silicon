    goto_if_ge(VAR_CULTURAL_PURITY,CULTURAL_PURITY_OPEN_B,CulturalPurity_Dialogue_WelcomeToB_Standalone)
    goto_if_ge(VAR_CULTURAL_PURITY,CULTURAL_PURITY_PAYWALL_B,CulturalPurity_Dialogue_AskDonation_BackroomguardB)
    call(CulturalPurity_Dialogue_BackroomguardB_Caw)
    closemessage
    goto_if_eq(VAR_CULTURAL_PURITY,CULTURAL_PURITY_READY_FOR_B,CulturalPurity_Dialogue_Begin_BackroomguardB)
    bufferitemname(STR_VAR_1,ITEM_QUEST_CULTURALPURITY_2)
    msgbox(format("I’m looking to play a game of Mahjong… but I’m missing a {STR_VAR_1}."),,SPEAKER_BACKROOMGUARDB)
