script Quest_Restoreespuleeoutskirts_Dialogue_InteractEspuleetradepersonE
{
    lock
    faceplayer
    goto_if_subquest_not_complete(QUEST_RESTOREESPULEEGYM,SUB_QUEST_5,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Incomplete_AskItem)
    goto_if_subquest_complete(QUEST_RESTOREESPULEEGYM,SUB_QUEST_5,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Complete)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Incomplete_AskItem
{
    msgbox(format("Lil' baby Pokemon are the best! Who cares if they aren't strong?"),,SPEAKER_ESPULEETRADEPERSONE)
    buffermapname(STR_VAR_3,MAP_CHASILLA)
    msgbox(format("I'd love to hatch a Shiny one day, but the {STR_VAR_3} Breeding Services are too pricey."),,SPEAKER_ESPULEETRADEPERSONE)
    msgbox(format("Apparently those 'breedjects' they get are lucky. I want some of those!"),,SPEAKER_ESPULEETRADEPERSONE)
    msgbox(format("Hey, do you happen to have any?"),MSGBOX_YESNO,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_TradeItem)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_DenyTrade)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_TradeItem
{
    checkitemspace(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_E,1)
    if(var(VAR_RESULT) == FALSE)
    {
        msgbox(format("If you make some space in your bag, I can give you something that'll power up certain Pokemon."),,SPEAKER_ESPULEETRADEPERSONE)
        closemessage
        release
        end
    }
    setvar(VAR_0x8009,SPECIES_EGG)
    chooseboxmon(SELECT_PC_MON_TRADE)
    waitstate
    cueobjecttalking(LOCALID_PLAYER)
    goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg
{
    callnative(Script_CheckIfMonIsOddEgg)
    switch(var(VAR_RESULT))
    {
        case QUEST_RESTOREESPULEEGYM_IS_REGULAR_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_RegularEgg)
        case QUEST_RESTOREESPULEEGYM_IS_ODD_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_AskEgg)
        case QUEST_RESTOREESPULEEGYM_IS_NOT_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_NotEgg)
    }
    goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_DenyTrade)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_RegularEgg
{
    buffermapname(STR_VAR_1,MAP_CHASILLA)
    msgbox(format("Hmm…"),,SPEAKER_ESPULEETRADEPERSONE)
    msgbox(format("This egg might be from {STR_VAR_1}, but it ain't one of the weird ones I'm looking for."),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_AskEgg
{
    askplayermon(format("Yes! This is the one! Can I have it?"),format("Aww. Come back when you've got one you're happy for me to have."),format("Come back to me when you have more healthy Pokemon."),SPEAKER_ESPULEETRADEPERSONE)
    goto_if_eq(VAR_TEMP_3,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_GiveEggUp)
    goto_if_eq(VAR_TEMP_3,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDeny)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_NotEgg
{
    msgbox(format("This… Is not an egg."),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_DenyTrade
{
    msgbox(format("Fine! But if you get one, don't hatch it! Bring it here!"),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_GiveEggUp
{
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_RESTOREESPULEEGYM,SUB_QUEST_5)
    msgbox(format("Ooh I can't wait to hatch this little guy!"),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    cueobjectplayer(LOCALID_CURENO_ESPUELEETRADEPERSONE)
    giveitem(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_E,1)
    bufferitemname(STR_VAR_1,ITEM_BOTTLE_CAP)
    buffermapname(STR_VAR_2,MAP_HALERBA_CITY)
    msgbox(format("Y'know there's a researcher in {STR_VAR_2} who'll make certain Pokemon stronger if you bring them a {STR_VAR_1}."),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDeny
{
    msgbox(format("Aww. Come back when you've got one you're happy for me to have."),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Complete
{
    goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Complete_AskItem)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_Complete_AskItem
{
    msgbox(format("I'd be overjoyed to take more of those Odd Eggs if you have them!"),MSGBOX_YESNO,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteTradeItem)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDenyTrade)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteTradeItem
{
    goto_if_quest_reward(QUEST_RESTOREESPULEEGYM,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_ExclaimHatchedMon)
    goto_if_quest_complete(QUEST_RESTOREESPULEEGYM,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_ExclaimHatchedMon)

    checkitemspace(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_E,1)
    if(var(VAR_RESULT) == FALSE)
    {
        bufferitemname(STR_VAR_1,ITEM_BOTTLE_CAP)
        msgbox(format("Hey! I'll give you another {STR_VAR_1} for another of those Odd Eggs!"),,SPEAKER_ESPULEETRADEPERSONE)
        msgbox(format("Somehow you don't have room in your bag for a {STR_VAR_1}. You gotta clean this thing out everyone once in a while, y'know!"),,SPEAKER_ESPULEETRADEPERSONE)
        closemessage
        release
        end
    }
    setvar(VAR_0x8009,SPECIES_EGG)
    chooseboxmon(SELECT_PC_MON_TRADE)
    waitstate
    cueobjecttalking(LOCALID_PLAYER)
    goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEggComplete)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDenyTrade
{
    msgbox(format("Fine! But if you get one, don't hatch it! Bring it here!"),,SPEAKER_ESPULEETRADEPERSONE)
    buffermapname(STR_VAR_1,MAP_CHASILLA)
    msgbox(format("I hope one day the {STR_VAR_1} Breeding Services will be a little more affordable."),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEggComplete
{
    callnative(Script_CheckIfMonIsOddEgg)
    switch(var(VAR_RESULT))
    {
        case QUEST_RESTOREESPULEEGYM_IS_REGULAR_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_RegularEgg)
        case QUEST_RESTOREESPULEEGYM_IS_ODD_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_AskEggComplete)
        case QUEST_RESTOREESPULEEGYM_IS_NOT_EGG: goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_NotEgg)
    }
    goto(Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDenyTrade)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonE_JudgeEgg_AskEggComplete
{
    buffermapname(STR_VAR_3,MAP_CHASILLA)
    askplayermon(format("Yes! This is the one! Can I have it?"),format("Fine! But if you get one, don't hatch it! Bring it here! I hope one day the {STR_VAR_3} Breeding Services will be a little more affordable."),format("Come back to me when you have more healthy Pokemon."),SPEAKER_ESPULEETRADEPERSONE)
    goto_if_eq(VAR_TEMP_3,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_GiveEggUpComplete)
    goto_if_eq(VAR_TEMP_3,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonE_CompleteDeny)
}

