{
    checkitem(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_C,1)
    goto_if_eq(VAR_RESULT,FALSE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Complete_DiscussItem)
    goto_if_eq(VAR_RESULT,TRUE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Complete_AskItem)
