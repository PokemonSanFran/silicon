{
    msgbox(format("If you find any more of those tickets, we have so many Odd Eggs that could use a home!"),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Complete_AskItem
{
    msgbox(format("Another Odd Egg, then? We'd thank you very kindly!"),MSGBOX_YESNO,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_TradeItem)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_DenyTrade)
