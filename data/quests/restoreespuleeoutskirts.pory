script Quest_Restoreespuleeoutskirts_Dialogue_InteractEspuleetradepersonD
{
    lock
    faceplayer
    goto_if_unset(FLAG_RECIEVED_NURSERY_EGG,Quest_Restoreespuleeoutskirts_Dialogue_EspuleetradepersonD_FirstEggOffer)
    goto_if_subquest_not_complete(QUEST_RESTOREESPULEEGYM,SUB_QUEST_4,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete)
    goto_if_subquest_complete(QUEST_RESTOREESPULEEGYM,SUB_QUEST_4,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Complete)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete
{
    checkitem(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_C,1)
    goto_if_eq(VAR_RESULT,FALSE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete_DiscussItem)
    goto_if_eq(VAR_RESULT,TRUE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete_AskItem)
}

script Quest_Restoreespuleeoutskirts_Dialogue_EspuleetradepersonD_FirstEggOffer
{
    msgbox(format("Lots of trainers opt not to take eggs if they find out that they're breedjects."),,SPEAKER_ESPULEETRADEPERSOND)
    msgbox(format("It's truly saddening. I wish every egg could have a good home."),,SPEAKER_ESPULEETRADEPERSOND)
    msgbox(format("I'm sensing you have a good heart. Perhaps you'd be willing to adopt an Egg?"),MSGBOX_YESNO,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_FirstEggAccept)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_FirstEggDeny)
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_NoRoomForEgg
{
    msgbox(format("Oh! But you don't have room for any new Pokemon! Come back when you do!"),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_FirstEggAccept
{
    startmenu_savescreen
    callnative(Script_GenerateAndGiveOddEgg)
    copyvar(VAR_TEMP_3,VAR_RESULT)
    setflag(FLAG_RECIEVED_NURSERY_EGG)
    goto_if_eq(VAR_RESULT,MON_CANT_GIVE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_NoRoomForEgg)
    msgbox(format("Wonderful! How nice it is to see this egg get a happy home."),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    cueobjectplayer(LOCALID_CHASILLA_BREEDING_ESPUELEETRADEPERSOND)
    playfanfare(MUS_OBTAIN_ITEM)
    msgbox(format("{PLAYER} recieved an Egg!"))
    waitmessage
    waitfanfare
    call_if_eq(VAR_TEMP_3,MON_GIVEN_TO_PC,BreedingCenter_Text_EggTransferredToPC)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_FirstEggDeny
{
    msgbox(format("I understand. It's a big responsibility."),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete_DiscussItem
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_RESTOREESPULEEGYM_ITEM_C)
    msgbox(format("The Daycare used to have a program wherein trainers from under-served communities would take in an Odd Egg in exchange for an {STR_VAR_1}."),,SPEAKER_ESPULEETRADEPERSOND)
    msgbox(format("But I haven't seen those tickets in a long time. I think they went away when Sharprise popped up."),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_Incomplete_AskItem
{
    bufferitemnameplural(STR_VAR_1,ITEM_QUEST_RESTOREESPULEEGYM_ITEM_C,2)
    msgbox(format("Hey! Got one of those nifty little {STR_VAR_1}?"),,SPEAKER_ESPULEETRADEPERSOND)
    msgbox(format("Would you…Perhaps give it to me? I would of course give you an Odd Egg now."),MSGBOX_YESNO,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_TradeItem)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_DenyTrade)
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_TradeItem
{
    startmenu_savescreen
    callnative(Script_GenerateAndGiveOddEgg)
    copyvar(VAR_TEMP_3,VAR_RESULT)
    removeitem(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_C,1)
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_RESTOREESPULEEGYM,SUB_QUEST_4)
    goto_if_eq(VAR_RESULT,MON_CANT_GIVE,Quest_Restoreespuleeoutskirts_EspuleetradepersonD_NoRoomForEgg)
    msgbox(format("Egg-cellent! Hehehe, another good home for what I'm sure is a good egg."),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    cueobjectplayer(LOCALID_CHASILLA_BREEDING_ESPUELEETRADEPERSOND)
    playfanfare(MUS_OBTAIN_ITEM)
    msgbox(format("{PLAYER} recieved an Egg!"))
    waitmessage
    waitfanfare
    call_if_eq(VAR_TEMP_3,MON_GIVEN_TO_PC,BreedingCenter_Text_EggTransferredToPC)
    closemessage
    release
    end
}

script Quest_Restoreespuleeoutskirts_EspuleetradepersonD_DenyTrade
{
    msgbox(format("No? How strange. The tickets don't serve any other purpose."),,SPEAKER_ESPULEETRADEPERSOND)
    closemessage
    release
    end
}

