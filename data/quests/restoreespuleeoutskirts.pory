    goto_if_eq(VAR_RESULT,YES,Quest_Restoreespuleeoutskirts_EspuleetradepersonB_CompleteTradeItem)
    goto_if_eq(VAR_RESULT,NO,Quest_Restoreespuleeoutskirts_EspuleetradepersonB_CompleteDenyTrade)
