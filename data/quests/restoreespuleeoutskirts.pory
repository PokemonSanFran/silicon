    msgbox(format("I can't wait to see what this hatches into!"),,SPEAKER_ESPULEETRADEPERSONE)
    closemessage
    cueobjectplayer(LOCALID_CURENO_ESPUELEETRADEPERSONE)
    giveitem(ITEM_QUEST_RESTOREESPULEEGYM_ITEM_E,1)
    closemessage
