//Quest_Getthebandbacktogether_
const PLAYER = OBJ_EVENT_ID_PLAYER

script Quest_Getthebandbacktogether_Script_Interact_AngeldeliverybikerC
{
    lock
    faceplayer
    goto_if_quest_complete(QUEST_GETTHEBANDBACKTOGETHER,Quest_Getthebandbacktogether_Dialogue_QuestComplete)
    goto_if_quest_reward(QUEST_GETTHEBANDBACKTOGETHER,Quest_Getthebandbacktogether_Dialogue_QuestReward)
    goto_if_quest_active(QUEST_GETTHEBANDBACKTOGETHER,Quest_Getthebandbacktogether_Dialogue_QuestActive)
    goto_if_quest_inactive(QUEST_GETTHEBANDBACKTOGETHER,Quest_Getthebandbacktogether_Dialogue_QuestInactive)
}

script Quest_Getthebandbacktogether_Dialogue_QuestComplete
{
    msgbox(format("Pedal power!"),,SPEAKER_ANGELDELIVERYBIKERC)
    msgbox(format("I think they’re talking about building a bike rental program around the city. Bicycles aren't expensive here, but they are in high demand so they’re constantly out of stock. This will make sure that people have consistent access without needing full ownership."),,SPEAKER_ANGELDELIVERYBIKERC)
    closemessage
    release
    end
}

script Quest_Getthebandbacktogether_Dialogue_QuestReward
{
    msgbox(format("Pedal power!"),,SPEAKER_ANGELDELIVERYBIKERC)
    msgbox(format("They’re all here! I’m so excited to see what everybody is going to do."),,SPEAKER_ANGELDELIVERYBIKERC)
    msgbox(format("I’ve been working on an experimental bike upgrade, and I think it’s ready for prime time!"),,SPEAKER_ANGELDELIVERYBIKERC)
    closemessage
    applymovement(LOCALID_ANGELDELIVERYBIKERC, AngelDelivery_Movement_BikerCCirclesAroundThePlayer)
    applymovement(PLAYER, AngelDelivery_Movement_PlayerLooksAtTheBikers)
    waitmovement(0)
    msgbox(format("Gotta adjust the gear ratio for hops…"),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
    closemessage
    applymovement(LOCALID_ANGELDELIVERYBIKERC, AngelDelivery_Movement_BikerCCirclesAroundThePlayer)
    applymovement(PLAYER, AngelDelivery_Movement_PlayerLooksAtTheBikers)
    waitmovement(0)
    msgbox(format("Saddle needs to be a few cm back to prevent wheelie collapse…"),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
    closemessage
    applymovement(LOCALID_ANGELDELIVERYBIKERC, AngelDelivery_Movement_BikerCCirclesAroundThePlayer)
    applymovement(PLAYER, AngelDelivery_Movement_PlayerLooksAtTheBikers)
    waitmovement(0)
    msgbox(format("Okay, the chain is lubed up like a Wooper…"),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
    closemessage
    applymovement(LOCALID_ANGELDELIVERYBIKERC, AngelDelivery_Movement_BikerCCirclesAroundThePlayer)
    applymovement(PLAYER, AngelDelivery_Movement_PlayerLooksAtTheBikers)
    waitmovement(0)
    bufferspeciesname(STR_VAR_1,SPECIES_SPOINK)
    msgbox(format("And finally the {STR_VAR_1} springs…"),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
    msgbox(format("All done. Your bike can do all kinds of tricks now!"),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
    msgbox(format("Our members can tell you about all kinds of tricks."),,SPEAKER_ANGELDELIVERYBIKERC, TAIL_WHISPER)
// PSF TODO redo movememnt once interior is done
    closemessage
    completequest(QUEST_GETTHEBANDBACKTOGETHER)
    release
    end
}

script Quest_Getthebandbacktogether_Dialogue_QuestActive
{
    msgbox(format("If you see another member of the Gear Grind Gang, can you let them know what we’re working on?"),,SPEAKER_ANGELDELIVERYBIKERC)
    msgbox(format("Make sure you’re riding your bike when you talk to them. Your flag shows them you’re the real deal."),,SPEAKER_ANGELDELIVERYBIKERC)
    closemessage
    release
    end
}

script Quest_Getthebandbacktogether_Dialogue_QuestInactive
{
    msgbox(format("Pedal power!"),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("The newest member of the Gear Grind Gang! How’s the bike treating you?"),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("I wanna pick your brain for a second."),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("I’m installing dividers in the living room, so that each section can be a room."),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("Don’t worry! I’m not renting them out like some slumlord."),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("It’s not ideal, but I want to convert this place from just a clubhouse to a real hacker house."),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("A lot of our members have talked about being able to live together and work on building something together. We don’t know what that is yet… "),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("but this is the first step!"),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("I want to get the word out, but I don’t want suits getting their eyes or ears on this. I wanna keep it real grassroots and I can’t trust that our phones aren’t being monitored!"),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("You travel around the region a lot, right? "),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("If you see another member of the Gear Grind Gang, can you let them know what we’re working on? Word of mouth is the only secure form of communication."),,SPEAKER_ANGELDELIVERYBIKERC)
        msgbox(format("Make sure you’re riding your bike when you talk to them. Your flag shows them you’re the real deal."),,SPEAKER_ANGELDELIVERYBIKERC)
        closemessage
    startquest(QUEST_GETTHEBANDBACKTOGETHER)
        release
        end
}

script Quest_Getthebandbacktogether_Dialogue_PedalPower
{
callnative(Script_Quest_Getthebandbacktogether_CountRemainingSubquests)
switch (var(VAR_RESULT))
{
    case 0: msgbox(format("Pedal power!"),,SPEAKER_ALICIA)
    case 1: msgbox(format("Pedal power!"),,SPEAKER_ALICIA)
    case 2: msgbox(format("Pedal power…"),,SPEAKER_ALICIA)
    case 3: msgbox(format("Pedal pride!"),,SPEAKER_ALICIA,,EMOTE_SWEAT)
    case 4: msgbox(format("Pedal… power?"),,SPEAKER_ALICIA,TAIL_WHISPER,EMOTE_SWEAT)
    default: return
}
return
}

