script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerA_Complete
{
    msgbox(format("It’s really cool that we’re all finally together, but we haven’t figured out what we want to do together."),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERA)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerB_Complete
{
    msgbox(format("I want to spin up a place where we can teach people how to repair their bikes, and people can borrow tools to make it happen."),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERB)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerC_Complete
{
    msgbox(format("GetthebandbacktogetherbikerB’s education center is great, but where are we gonna do the actual education? It’s already cramped in here."),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERC)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerD_Complete
{
    msgbox(format("I’m trying to get the others onboard with starting a bike building operation. We custom build bikes and then give them to people who otherwise can’t afford them around the region."),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERD)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerE_Complete
{
    msgbox(format("Programs like GetthebandbacktogetherbikerD’s idea is how we get more bikers in Resido. I love it!"),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERE)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerF_Complete
{
    msgbox(format("Do we have to do anything? Can’t we just chill and ride bikes like we always do?"),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERF)
}

script Quest_Getthebandbacktogether_Dialogue_GetthebandbacktogetherbikerG_Complete
{
    buffermapname(STR_VAR_1,MAP_OROLAND)
    msgbox(format("My sister used to own a bicycle cafe in {STR_VAR_1}. It closed down a few years ago but I wonder if we could make it work."),MSGBOX_NPC,SPEAKER_GETTHEBANDBACKTOGETHERBIKERG)
}
