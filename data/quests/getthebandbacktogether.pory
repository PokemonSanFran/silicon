script Quest_Getthebandbacktogether_Complete_GetthebandbacktogetherbikerA
{
    specialvar(VAR_TEMP_1, GetPlayerAvatarBike)
    if (var(VAR_TEMP_1) == 0)
    {
        return
    }
    subquestmenu(QUEST_MENU_COMPLETE_QUEST,QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_1)
    callnative(Quest_Getthebandbacktogether_CountRemainingSubquestsTryProgressReward)
    call(Quest_Getthebandbacktogether_Dialogue_PedalPower)
    msgbox(format("Pedal power!"),,SPEAKER_GETTHEBANDBACKTOGETHERBIKERA)
    msgbox(format("Are you new?"),,SPEAKER_GETTHEBANDBACKTOGETHERBIKERA)
    msgbox(format("Just joined."),,SPEAKER_ALICIA)
    msgbox(format("AngeldeliverybikerC sent me to tell you about the new hacker house."),,SPEAKER_ALICIA)
    closemessage
    fadescreen(FADE_TO_BLACK)
    delay(30)
    fadescreen(FADE_FROM_BLACK)
    msgbox(format("Oh finally! I’m gonna go check it out now."),,SPEAKER_GETTHEBANDBACKTOGETHERBIKERA)
    closemessage
    applymovement(LOCALID_GETTHEBANDBACKTOGETHERBIKERA, moves(walk_up * 6))
    fadeandremovelasttalked
    release
    end
}

