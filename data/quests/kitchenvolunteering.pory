script Kitchenvolunteering_Script_Interact_Restaurantexpansionbusser
{
    locktarget
    goto_if_quest_complete(QUEST_KITCHENVOLUNTEERING,Kitchenvolunteering_Script_SecondInteract)
    goto_if_quest_reward(QUEST_KITCHENVOLUNTEERING,Kitchenvolunteering_Dialogue_Reward)
    goto_if_quest_active(QUEST_KITCHENVOLUNTEERING,Kitchenvolunteering_Dialogue_YoureNotDone)
    goto(Kitchenvolunteering_Dialogue_StartQuest)
}

script Kitchenvolunteering_Dialogue_StartQuest
{
    checkitemspace(ITEM_QUEST_KITCHENVOLUNTEERING_KEY,1)
    if (var(VAR_RESULT) == FALSE)
    {
        msgbox(format("Make some room in your bag if you’re here to help! I gotta give you somethin’."),MSGBOX_NPC,SPEAKER_RESTAURANTEXPANSIONBUSSER)
        return
    }
    lock
    faceplayer
    msgbox(format("You're the Trainer that got me this gig, {PLAYER}!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("It’s nice to see ya."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("It's hard to find more people to pitch in, so I’m the only one running around."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("I can't bus tables and grab stuff some downstairs, can you help me out?"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("I need someone to go down to the basement and help me restock the shelves with what’s down there."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    call(Kitchenvolunteering_Script_BufferItemNameA)
    msgbox(format("We need {STR_VAR_1}, {STR_VAR_2}, {STR_VAR_3} …"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    call(Kitchenvolunteering_Script_BufferItemNameB)
    msgbox(format("Oh, {STR_VAR_1}, and {STR_VAR_2}!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("Don’t freak out on me but there are some wild Pokemon down there, okay? They’re not after the food or anything they just, uh…Live there."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    call(Kitchenvolunteering_Script_GiveKey)
    callnative(Quest_Kitchenvolunteering_BufferNumberOfKitchenItems)
    msgbox(format("I almost forgot to give ya the key. Come back when you got those {STR_VAR_3} things, okay?"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    startquest(QUEST_KITCHENVOLUNTEERING)
    call(Kitchenvolunteering_Script_ReturnToWork)
}

script Kitchenvolunteering_Script_ReturnToWork
{
    applymovement(LOCALID_FLOWERS_RESTAURANTEXPANSIONBUSSER,Common_Movement_FaceOriginalDirection)
    waitmovement(LOCALID_FLOWERS_RESTAURANTEXPANSIONBUSSER)
    release
}

script Kitchenvolunteering_Dialogue_YoureNotDone
{
    lock
    msgbox(format("Hope that kid gets back soon with the stuff…"),,SPEAKER_RESTAURANTEXPANSIONBUSSER,TAIL_WHISPER)
    closemessage
    call(Kitchenvolunteering_Script_ReturnToWork)
    end
}

script Kitchenvolunteering_Script_RemoveItem
{
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_KEY,1)
    questmenu(QUEST_MENU_CHECK_COMPLETE,QUEST_KITCHENVOLUNTEERING)
    if (!var(VAR_RESULT))
    {
        call(Kitchenvolunteering_Script_RemoveAllItems)
    }
    else
    {
        call(Kitchenvolunteering_Script_RemoveDailyItem)
    }
}

script Kitchenvolunteering_Script_RemoveAllItems
{
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_A,1)
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_B,1)
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_C,1)
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_D,1)
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_E,1)
    removeitem(ITEM_QUEST_KITCHENVOLUNTEERING_KEY,1)
}

script Kitchenvolunteering_Script_RemoveDailyItem
{
    copyvar(VAR_0x8004,VAR_QUEST_KITCHEN_ASSIGNED_ITEMS)
    removeitem(VAR_0x8004,1)
}

script Kitchenvolunteering_Dialogue_Reward
{
    lock
    faceplayer
    call(Kitchenvolunteering_Script_SetFlagsMoveItems)
    msgbox(format("Hey, you got back here fast!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("You got all the stuff I asked for? And the key too, yeah?"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    cueobjecttalking(LOCALID_PLAYER)
    msgbox(format("Hey, nice!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("Gee kid you really came through for me! Again!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("I can’t thank ya enough."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("You’re special. Drinks on the house next time you’re here! Or, uh…Apple Juice, or somethin’. Although I guess its technically free anyways…"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    completequest(QUEST_KITCHENVOLUNTEERING)
    release
    end
}

script Kitchenvolunteering_Script_SecondInteract
{
    lock
    if (flag(FLAG_DAILY_QUEST_KITCHENVOLUNTEERING))
    {
        goto(Kitchenvolunteering_Dialogue_TooBusy)
    }

    checkitem(ITEM_QUEST_KITCHENVOLUNTEERING_KEY,1)
    if (var(VAR_RESULT))
    {
        goto(Kitchenvolunteering_Script_CheckForItem)
        goto(Kitchenvolunteering_Dialogue_YoureNotDone)
    }

    goto(Kitchenvolunteering_Dialogue_RepeatQuest)
}

script Kitchenvolunteering_Script_CheckForItem
{
    callnative(Quest_Kitchenvolunteering_CheckForDailyItem)
    if (var(VAR_RESULT))
    {
        goto(Kitchenvolunteering_Dialogue_DailyReward)
        end
    }
}

script Kitchenvolunteering_Script_SetFlagsMoveItems
{
    setflag(FLAG_DAILY_QUEST_KITCHENVOLUNTEERING)
    call(Kitchenvolunteering_Script_RemoveItem)
    callnative(RandomlyBoostPartyMemberFriendship)
}

script Kitchenvolunteering_Dialogue_DailyReward
{
    faceplayer
    call(Kitchenvolunteering_Script_SetFlagsMoveItems)
    callnative(Quest_Kitchenvolunteering_BufferRandomPantryItemName)
    msgbox(format("How ya doin’, kid?"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("Hey, great. Thanks for the {STR_VAR_1}!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    cueobjecttalking(LOCALID_PLAYER)
    msgbox(format("Appreciate the support. It means a lot."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    release
    end
}

script Kitchenvolunteering_Dialogue_TooBusy
{
    lock
    msgbox(format("Man, its never ending!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER,TAIL_WHISPER)
    closemessage
    call(Kitchenvolunteering_Script_ReturnToWork)
    end
}

script Kitchenvolunteering_Script_BufferSingleItemName
{
    copyvar(VAR_0x8004,VAR_QUEST_KITCHEN_ASSIGNED_ITEMS)
    bufferitemname(STR_VAR_1,VAR_0x8004)
}

script Kitchenvolunteering_Script_BufferItemNameA
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_KITCHENVOLUNTEERING_A)
    bufferitemname(STR_VAR_2,ITEM_QUEST_KITCHENVOLUNTEERING_B)
    bufferitemname(STR_VAR_3,ITEM_QUEST_KITCHENVOLUNTEERING_C)
}

script Kitchenvolunteering_Script_BufferItemNameB
{
    bufferitemname(STR_VAR_1,ITEM_QUEST_KITCHENVOLUNTEERING_D)
    bufferitemname(STR_VAR_2,ITEM_QUEST_KITCHENVOLUNTEERING_E)
}

script Kitchenvolunteering_Dialogue_RepeatQuest
{
    lock
    faceplayer
    msgbox(format("Hey, you're back!"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    msgbox(format("I had a feeling you needed the help. "),,SPEAKER_ALICIA)
    msgbox(format("The pace is pretty wild! A lot of the newbies get all freaked out by the basement and don’t come back."),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    closemessage
    call(Kitchenvolunteering_Script_GiveKey)
    callnative(KitchenvolunteeringFunc_ChooseRandomPantryItem)
    msgbox(format("Get me some {STR_VAR_1} will ya?"),,SPEAKER_RESTAURANTEXPANSIONBUSSER)
    release
    end
}

script Kitchenvolunteering_Script_GiveKey
{
    cueobjectplayer(LOCALID_FLOWERS_RESTAURANTEXPANSIONBUSSER)
    callnative(GenerateMazeLayoutSeed)
    giveitem(ITEM_QUEST_KITCHENVOLUNTEERING_KEY,1)
}

script Kitchenvolunteering_Script_FindItem
{
    special(KitchenvolunteeringFunc_GeneratePantryItem)
    callstd(STD_FIND_ITEM)
    special(KitchenvolunteeringFunc_CheckProgressAndSetReward)
    end
}

