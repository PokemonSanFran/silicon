mapscripts PerlaciaCity_Gym_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        call(EnterEmrys_LeaderPosition_Script)
        call(Quest_Alohafromalola_SetLeaderPosition_Battle_Script)
		call(PerlaciaCity_Gym_LeaderVisibility_Script)
    }
    MAP_SCRIPT_ON_FRAME_TABLE[
        VAR_EMRYS_STATE,EXHIBITION_READY: Quest_Alohafromalola_StartBattle_Dialogue
    ]
}

script PerlaciaCity_Gym_LeaderVisibility_Script
{
    if (var(VAR_STORYLINE_STATE) < STORY_COMPLETE_ARANTRAZ)
	{
        return
	}

    call_if_quest_not_complete(QUEST_BUILDINGANEXHIBIT,Quest_Rematches_Script_HideEmrys)
}

script PerlaciaCity_Gym_EventScript_0AF40D0B
{
    trainerbattle_single(TRAINER_0AF40D0B,format("I am a Perlacia Gym Trainer"),format("I lost!"))
    msgbox(format("You defeated me!"),MSGBOX_AUTOCLOSE)
    end
}

