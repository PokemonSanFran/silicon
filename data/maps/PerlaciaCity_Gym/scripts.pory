script Emrys_Event_Script 
{
    lockall
	goto_if_quest_complete(QUEST_BUILDINGANEXHIBIT,Rematches_Script_Emrys)
    switch (var (VAR_GYM_3_STATE)) 
	{
		default: goto(EnterEmrys_MuseumArrangement_Dialogue)
		case PERLACIA_GYM_SAVE_BEFORE_BATTLE: goto(EnterEmrys_StartBattle_Script)
		case PERLACIA_GYM_LEADER_DEFEATED:
			goto_if_set(FLAG_TEMP_2,EnterEmrys_PostBattle_Dialogue2)
			goto(EnterEmrys_PostBattle_Dialogue)
    }
}

