mapscripts Route13_MapScripts {
    MAP_SCRIPT_ON_TRANSITION{
        call(Quest_Ultrawormholeresearch_ControlTotemVisibility)
    }
    MAP_SCRIPT_ON_RESUME{
        call(Quest_Ultrawormholeresearch_TryRemoveTotem_Script)
    }
}

script Route13_Script_Interact_BodegaburnoutDeliveryStrengthI
{
    call_if_subquest_not_complete(QUEST_BODEGABURNOUT,SUB_QUEST_5,Quest_Bodegaburnout_Script_Handle_BodegaburnoutDeliveryStrengthI)
    bufferitemname(STR_VAR_1,ITEM_DUSK_STONE)
    bufferspeciesname(STR_VAR_2,SPECIES_DOUBLADE)
    msgbox(format("I can finally use this {STR_VAR_1} to evolve my {STR_VAR_2}!"),,SPEAKER_BODEGABURNOUTDELIVERYSTRENGTHI)
    closemessage
    release
    end
}
