//CurenoPort_GearGrindGangHouse_
//CurenoPort_GearGrindGangHouse_Text_

mapscripts CurenoPort_GearGrindGangHouse_MapScripts {
    MAP_SCRIPT_ON_TRANSITION {
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_1,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerA)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_2,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerB)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_3,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerC)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_4,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerD)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_5,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerE)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_6,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerF)
        call_if_subquest_not_complete(QUEST_GETTHEBANDBACKTOGETHER,SUB_QUEST_7,Quest_Getthebandbacktogether_Script_HideUntilComplete_GetthebandbacktogetherbikerG)
    }
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE
        [
            VAR_TEMP_0, 0: CurenoPort_GearGrindGangHouse_Script_TryToPutPlayerOnBike
        ]
        MAP_SCRIPT_ON_FRAME_TABLE
        [
            VAR_TEMP_0, 1: CurenoPort_GearGrindGangHouse_Script_CheckAcceptance
        ]
}

script CurenoPort_GearGrindGangHouse_Script_TryToPutPlayerOnBike
{
    addvar(VAR_TEMP_0, 1)
    returnqueststate(QUEST_ANGELDELIVERY)
    if (var(VAR_RESULT) >= QUEST_MENU_SET_REWARD)
    {
        specialvar(VAR_RESULT,GetPlayerAvatarBike)
        if (var(VAR_RESULT) == 0)
        {
            getonoffbike(FALSE)
        }
    }
}

script CurenoPort_GearGrindGangHouse_Script_CheckAcceptance
{
    addvar(VAR_TEMP_0,1)
    lock
    returnqueststate(QUEST_ANGELDELIVERY)
    switch (var(VAR_RESULT))
    {
        case QUEST_MENU_SET_REWARD:
            goto(AngelDelivery_Dialogue_PreBattle)
        case QUEST_MENU_COMPLETE_QUEST:
            release
            end
        default:
            goto(CurenoPort_GearGrindGangHouse_Dialogue_KickOut)
    }
}

script CurenoPort_GearGrindGangHouse_Dialogue_GuardsBlockDoor{
    applymovement(LOCALID_ANGELDELIVERYBIKERC, moves(face_left, face_right, face_up, face_down, step_end))
    applymovement(LOCALID_ANGELDELIVERYBIKERD, moves(face_left, face_right, face_up, face_down, step_end))

    waitmovement(LOCALID_ANGELDELIVERYBIKERD)
    msgbox(format("Gear Grind Gang only."),,SPEAKER_ANGELDELIVERYBIKERC)
    msgbox(format("You'll have to leave."),,SPEAKER_ANGELDELIVERYBIKERD)
    closemessage
    return
}

script CurenoPort_GearGrindGangHouse_Dialogue_KickOut
{
   call(CurenoPort_GearGrindGangHouse_Dialogue_GuardsBlockDoor)
    fadeblackandsetremovewarpfadeflag
    warp(MAP_CURENO_PORT,2,21)
    release
    end
}

