mapscripts CapheCity_Pantry_MapScripts{
    MAP_SCRIPT_ON_LOAD{
    }
    MAP_SCRIPT_ON_TRANSITION
    {
        call_if_quest_complete(QUEST_RESTAURANTEXPANSION2,Quest_Restaurantexpansion2_Script_HideFlowersBelen)
        call_if_subquest_not_complete(QUEST_RESTAURANTEXPANSION2,SUB_QUEST_1,Quest_Restaurantexpansion2_Script_HideFlowersRestaurantexpansionhostess)
        call_if_subquest_not_complete(QUEST_RESTAURANTEXPANSION2,SUB_QUEST_2,Quest_Restaurantexpansion2_Script_HideFlowersRestaurantexpansionchef)
        call_if_subquest_not_complete(QUEST_RESTAURANTEXPANSION2,SUB_QUEST_3,Quest_Restaurantexpansion2_Script_HideFlowersRestaurantexpansionlinecook)
        call_if_subquest_not_complete(QUEST_RESTAURANTEXPANSION2,SUB_QUEST_4,Quest_Restaurantexpansion2_Script_HideFlowersRestaurantexpansionbusser)
    }
}
const PLAYER = OBJ_EVENT_ID_PLAYER

script CapheCity_Pantry_CheckDoor_Script{
    msgbox(format("The door is locked."),MSGBOX_AUTOCLOSE)

    checkitem(ITEM_STORAGE_KEY,1)

    if(var(VAR_RESULT))
    {
        goto(CapheCity_Pantry_UnlockDoor_Script)
    }
    end
}

script CapheCity_Pantry_UnlockDoor_Script{
    bufferitemname(STR_VAR_1,ITEM_QUEST_KITCHENVOLUNTEERING_KEY)
    msgbox(format("Use the {STR_VAR_1} to unlock the door?"),MSGBOX_YESNO)

    if(var(VAR_RESULT) == YES)
    {
        closemessage
        warpdoor(MAP_CAPHE_CITY_PANTRY_MAZE,0)
        waitstate
        end
    }
    closemessage
    end
}

