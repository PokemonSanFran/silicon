mapscripts Route1_MapScripts {
    MAP_SCRIPT_ON_TRANSITION{
        call(Quest_ArtisanBalls2_CheckTrainerA_Script)
        call(Quest_Ultrawormholeresearch_ControlTotemVisibility)
    }
    MAP_SCRIPT_ON_LOAD
    {
    call(Quest_GardenCleanUp_ClearGarden_Script)
    }
    MAP_SCRIPT_ON_RESUME
    {
        call(Quest_Ultrawormholeresearch_TryRemoveTotem_Script)
    }
}

script Route1_Script_Interact_Quest_Restaurantexpansionhostess
{
    trainerbattle_single(TRAINER_QUEST_RESTAURANTEXPANSIONHOSTESS,format("What can I get you to eat today?"),format("I think the kitchen 86'd a win!!"),Route1_Script_Interact_Quest_Restaurantexpansionhostess)
    call_if_quest_active(QUEST_RESTAURANTEXPANSION2,Quest_Restaurantexpansion2_Complete_Restaurantexpansionhostess)
    msgbox(format("Haha, I’m so silly! I used to work as a server, but those days are long gone."),,SPEAKER_RESTAURANTEXPANSIONHOSTESS)
    closemessage
    release
    end
// PSF TODO Oh wow, extra spicy I see!
}

script Route1_Script_Interact_BodegaburnoutDeliveryB
{
    trainerbattle_single(TRAINER_QUEST_BODEGABURNOUTDELIVERYB,format("Argh! Until my stuff gets here, I’m taking it out on you!"),format("How embarrassing…"),Route1_Script_Interact_BodegaburnoutDeliveryB)
// PSF TODO BodegaburnoutDeliveryB: Ha! Rage does make me stronger!
    call_if_subquest_not_complete(QUEST_BODEGABURNOUT,SUB_QUEST_3,Quest_Bodegaburnout_Script_Handle_BodegaburnoutDeliveryB)
    bufferitemname(STR_VAR_1,ITEM_POTION)
    msgbox(format("Honestly, in the time I spent waiting here, I could have gone and bought a {STR_VAR_1} myself."),,SPEAKER_BODEGABURNOUTDELIVERYB)
    closemessage
    release
    end
}
