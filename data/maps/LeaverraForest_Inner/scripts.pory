mapscripts LeaverraForest_Inner_MapScripts
{
    MAP_SCRIPT_ON_TRANSITION
    {
        setflag(FLAG_VISITED_LEAVERRA_FOREST)
        call(EnterTheMaster_LeaverraForest_Inner_ObjectSetup_Script)
    }
    MAP_SCRIPT_ON_FRAME_TABLE
    [
        VAR_LEAVERRA_FOREST_STATE, LEAVERRA_FOREST_MAZE_COMPLETE: EnterTheMaster_ClearingIntro_Dialogue
        VAR_LEAVERRA_FOREST_STATE, FINISHED_FRANK_PUZZLES: HaveYouSeenTheNews_AskHelp_Dialogue
    ]
}

script LeaverraForest_Frank_Interact_Script 
{
    lock
    faceplayer
	goto_if_eq(VAR_STORYLINE_STATE,STORY_CLEAR,Rematches_Script_Frank)
	goto_if_eq(VAR_LEAVERRA_FOREST_STATE,POST_HAVE_YOU_SEEN_THE_NEWS,HaveYouSeenTheNews_Dialogue_Deputized)
	call(EnterTheMaster_ExplainRobots_Dialogue)
	closemessage
	release
	end
}
