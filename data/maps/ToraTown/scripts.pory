mapscripts ToraTown_MapScripts {
	MAP_SCRIPT_ON_RESUME
	{
		callnative(WarpTaxiAfterCutscene)
	}
    MAP_SCRIPT_ON_TRANSITION {
        call(WowYoureStrong_HideObject_Script)
    }
    MAP_SCRIPT_ON_LOAD{
       call(Quest_ArtisanBalls3_ChangeDoorMetatile_Script)
    }
    MAP_SCRIPT_ON_FRAME_TABLE [
        VAR_SHARPRISESPIRE_CONFERENCE_STATE, DEFEATED_THIRD_LEADER: WowYoureStrong_WalkToPlayer_Script
        VAR_TEMP_1, 0: SwagbagContinued_Dialogue_StartDexnav
        FLAG_VISITED_TORA_TOWN, FALSE: Generic_Mappreview
    ]
}

script ToraTown_Dialogue_Trash
{
    lock
    callnative(Script_Quest_Freetheinnocent_ShouldDiscoverCup)
    goto_if_eq(VAR_RESULT,TRUE,Quest_Freetheinnocent_Dialogue_Trashcan)
    msgbox(format("It’s a can. For trash."))
    closemessage
    release
    end
}

