mapscripts IrisinaTown_MapScripts
{
	MAP_SCRIPT_ON_RESUME
	{
		callnative(WarpTaxiAfterCutscene)
	}
    MAP_SCRIPT_ON_TRANSITION
    {
        call_if_subquest_complete(QUEST_RESTOREZENZUGYM,SUB_QUEST_2,RestoreZenzuIsland_Script_HideDrughelmettester)
    }

    MAP_SCRIPT_ON_FRAME_TABLE
    [
        FLAG_VISITED_IRISINA_TOWN, FALSE: Generic_Mappreview
        VAR_STORYLINE_STATE, STORY_EAST_RESIDO_COMPLETE: TheStrikeStrikesBack_PhoneCall_Dialogue
    ]
}
